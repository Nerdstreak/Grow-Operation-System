@page "/einstellungen"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject NavigationManager Nav

<div class="topbar">
    <span class="topbar-title">Einstellungen</span>
    <div class="topbar-right">
        <a href="/settings/backup" class="btn">DB-Backup</a>
    </div>
</div>

<div class="page-scroll">
    <div class="settings-grid">

        @* Home Assistant *@
        <div>
            <div class="section-label">Home Assistant</div>
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="panel-card-title">Verbindung</span>
                    <div class="ha-status @(_ha.IsConfigured ? "connected" : "disconnected")">
                        <div class="status-dot"></div>
                        @(_ha.IsConfigured ? "Konfiguriert" : "Nicht konfiguriert")
                    </div>
                </div>
                <div style="padding:16px 14px; display:grid; gap:12px">
                    <div class="two-col-grid">
                        <div class="field">
                            <label>Base URL</label>
                            <input @bind="_ha.BaseUrl" placeholder="http://homeassistant.local:8123" />
                        </div>
                        <div class="field">
                            <label>Access Token</label>
                            <input type="password" @bind="_ha.AccessToken" placeholder="Long-Lived Access Token" />
                        </div>
                    </div>
                    <label style="display:flex; align-items:center; gap:8px; font-size:13px; cursor:pointer">
                        <input type="checkbox" @bind="_ha.Enabled" />
                        <span>Home-Assistant-Verbindung aktivieren</span>
                    </label>
                    @if (_haSaved)
                    {
                        <div style="font-size:12px; color:var(--green); padding:6px 10px; background:oklch(74% 0.19 145 / 0.1); border-radius:6px; border:1px solid oklch(74% 0.19 145 / 0.25)">Verbindung gespeichert.</div>
                    }
                    <button class="btn" style="width:fit-content" @onclick="SaveHa">Verbindung speichern</button>
                </div>
            </div>
        </div>

        @* Zelte *@
        @foreach (var tent in _tents)
        {
            var t = tent;
            <div>
                <div class="section-label">Zelt · @t.Name</div>
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">@t.Name</span>
                        <span class="panel-card-count">@t.ActiveGrowCount aktive Runs</span>
                    </div>
                    <div style="padding:16px 14px; display:grid; gap:12px">
                        <div class="two-col-grid">
                            <div class="field">
                                <label>Name</label>
                                <input @bind="t.Name" />
                            </div>
                            <div class="field">
                                <label>Typ</label>
                                <input @bind="t.Kind" />
                            </div>
                            <div class="field">
                                <label>Temperatur Entity</label>
                                <input @bind="t.TemperatureEntityId" placeholder="sensor.ac_infinity_temperature" />
                            </div>
                            <div class="field">
                                <label>Luftfeuchte Entity</label>
                                <input @bind="t.HumidityEntityId" placeholder="sensor.ac_infinity_humidity" />
                            </div>
                            <div class="field">
                                <label>VPD Entity</label>
                                <input @bind="t.VpdEntityId" placeholder="sensor.ac_infinity_vpd" />
                            </div>
                            <div class="field">
                                <label>Licht / Status Entity</label>
                                <input @bind="t.LightEntityId" placeholder="switch.ac_infinity_light" />
                            </div>
                            <div class="field">
                                <label>Lichtzyklus</label>
                                <input @bind="t.LightCycle" placeholder="18/6 oder 12/12" />
                            </div>
                            <div class="field">
                                <label>PPFD Entity</label>
                                <input @bind="t.PpfdEntityId" placeholder="sensor.hauptzelt_ppfd" />
                            </div>
                            <div class="field">
                                <label>PPFD Zielwert</label>
                                <input @bind="t.PpfdTarget" placeholder="650" />
                            </div>
                            <div class="field">
                                <label>Reservoir pH Entity</label>
                                <input @bind="t.ReservoirPhEntityId" placeholder="sensor.rdwc_ph" />
                            </div>
                            <div class="field">
                                <label>Reservoir EC Entity</label>
                                <input @bind="t.ReservoirEcEntityId" placeholder="sensor.rdwc_ec" />
                            </div>
                            <div class="field">
                                <label>Wasserstand Entity</label>
                                <input @bind="t.ReservoirLevelEntityId" placeholder="sensor.rdwc_level_liters" />
                            </div>
                            <div class="field">
                                <label>Wassertemperatur Entity</label>
                                <input @bind="t.ReservoirTempEntityId" placeholder="sensor.rdwc_water_temp" />
                            </div>
                            <div class="field">
                                <label>ORP Sensor</label>
                                <input @bind="t.OrpEntityId" placeholder="sensor.rdwc_orp" />
                            </div>
                            <div class="field">
                                <label>Gelöster Sauerstoff</label>
                                <input @bind="t.DissolvedOxygenEntityId" placeholder="sensor.rdwc_do" />
                            </div>
                            <div class="field">
                                <label>CO₂ ppm</label>
                                <input @bind="t.Co2EntityId" placeholder="sensor.hauptzelt_co2" />
                            </div>
                            <div class="field">
                                <label>Kamera Entity</label>
                                <input @bind="t.CameraEntityId" placeholder="camera.hauptzelt_overview" />
                            </div>
                        </div>
                        <div class="field">
                            <label>Notizen</label>
                            <textarea rows="3" @bind="t.Notes"></textarea>
                        </div>
                        @if (_tentSaved.Contains(t.Id))
                        {
                            <div style="font-size:12px; color:var(--green); padding:6px 10px; background:oklch(74% 0.19 145 / 0.1); border-radius:6px; border:1px solid oklch(74% 0.19 145 / 0.25)">@t.Name gespeichert.</div>
                        }
                        <button class="btn" style="width:fit-content" @onclick='() => SaveTent(t)'>@t.Name speichern</button>
                    </div>
                </div>
            </div>
        }

        @* Datenbank *@
        <div>
            <div class="section-label">Datenbank</div>
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="panel-card-title">SQLite</span>
                </div>
                <div style="padding:16px 14px; display:grid; gap:12px">
                    <div style="display:grid; gap:8px; font-size:12px">
                        <div style="display:flex; justify-content:space-between">
                            <span style="color:var(--muted)">Aktive Grows</span>
                            <span style="font-family:var(--mono)">@_stats.ActiveGrows</span>
                        </div>
                        <div style="display:flex; justify-content:space-between">
                            <span style="color:var(--muted)">Gesamt Grows</span>
                            <span style="font-family:var(--mono)">@_stats.TotalGrows</span>
                        </div>
                        <div style="display:flex; justify-content:space-between">
                            <span style="color:var(--muted)">Messungen</span>
                            <span style="font-family:var(--mono)">@_stats.Measurements</span>
                        </div>
                    </div>
                    <a href="/settings/backup" class="btn" style="width:fit-content">Backup herunterladen</a>
                </div>
            </div>
        </div>

        @* App-Info *@
        <div>
            <div class="section-label">App</div>
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="panel-card-title">Grow OS</span>
                </div>
                <div style="padding:16px 14px; display:grid; gap:8px; font-size:12px">
                    <div style="display:flex; justify-content:space-between">
                        <span style="color:var(--muted)">Version</span>
                        <span style="font-family:var(--mono)">Blazor UI · Phase 2</span>
                    </div>
                    <div style="display:flex; justify-content:space-between">
                        <span style="color:var(--muted)">Framework</span>
                        <span style="font-family:var(--mono)">.NET 8 · Blazor Server</span>
                    </div>
                    <div style="display:flex; justify-content:space-between">
                        <span style="color:var(--muted)">Datenbank</span>
                        <span style="font-family:var(--mono)">SQLite (WAL)</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private HomeAssistantSettings _ha = new();
    private List<Tent> _tents = new();
    private DashboardStats _stats = new();
    private bool _haSaved;
    private HashSet<int> _tentSaved = new();

    protected override Task OnInitializedAsync()
    {
        _ha    = GrowRepo.GetHomeAssistantSettings();
        _tents = GrowRepo.GetTents();
        _stats = GrowRepo.GetDashboardStats();
        return Task.CompletedTask;
    }

    private void SaveHa()
    {
        GrowRepo.SaveHomeAssistantSettings(_ha);
        _haSaved = true;
    }

    private void SaveTent(Tent tent)
    {
        GrowRepo.UpdateTent(tent);
        _tentSaved.Add(tent.Id);
    }
}
