@page "/grows"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject WeekCounterService WeekCounter
@inject NavigationManager Nav

<div class="topbar">
    <span class="topbar-title">Aktive Grows</span>
    <div class="topbar-right">
        <a href="/grows/create" class="btn btn-primary">+ Neuer Run</a>
    </div>
</div>

<div class="page-scroll">

    @* Stats *@
    <div class="stats-row">
        <div class="stat-chip"><strong>@_grows.Count</strong>Aktive Runs</div>
        <div class="stat-chip"><strong>@_grows.Count(g => g.MediumType == MediumType.Hydro)</strong>Hydro</div>
        <div class="stat-chip"><strong>@_grows.Count(g => g.MediumType != MediumType.Hydro)</strong>Soil / Coco</div>
    </div>

    @* Tabelle *@
    <div class="data-table">
        <div class="data-table-header grows-cols">
            <span>Name</span>
            <span>Zelt</span>
            <span>Phase</span>
            <span>EC / pH</span>
            <span>Woche</span>
            <span></span>
        </div>

        @if (_loading)
        {
            <div class="empty-hint">Lade Daten…</div>
        }
        else if (!_grows.Any())
        {
            <div class="empty-hint">Keine aktiven Grows gefunden.</div>
        }
        else
        {
            @foreach (var g in _grows)
            {
                var week = WeekCounter.Calculate(g);
                <div class="data-row grows-cols" @onclick='() => Nav.NavigateTo($"/grows/{g.Id}")'>
                    <div>
                        <div class="row-name">@g.Name</div>
                        <div class="row-sub">@g.Strain @(g.Breeder is not null ? $"· {g.Breeder}" : "")</div>
                    </div>
                    <div class="row-muted">@(g.TentName ?? "–")</div>
                    <div>
                        <span class="badge @StageBadge(week.State)">@week.Label</span>
                    </div>
                    <div>
                        @if (g.LatestMeasurement is { } m)
                        {
                            <div class="row-val">@(m.ReservoirEc?.ToString("0.00") ?? "–") <span style="color:var(--faint);font-size:11px">mS</span></div>
                            <div class="row-sub">pH @(m.ReservoirPh?.ToString("0.0") ?? "–")</div>
                        }
                        else
                        {
                            <div class="row-muted">–</div>
                        }
                    </div>
                    <div class="row-val" style="font-size:12px">@week.Label</div>
                    <div>
                        <button class="tc-open-btn" @onclick:stopPropagation="true"
                                @onclick='() => Nav.NavigateTo($"/grows/{g.Id}")'>
                            →
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private List<GrowRun> _grows = new();

    protected override Task OnInitializedAsync()
    {
        _grows   = GrowRepo.GetActiveGrows();
        _loading = false;
        return Task.CompletedTask;
    }

    private static string StageBadge(GrowCounterState s) => s switch
    {
        GrowCounterState.Vegetating    => "badge-ok",
        GrowCounterState.Flowering     => "badge-warn",
        GrowCounterState.Autoflowering => "badge-warn",
        _                              => "badge-neutral",
    };
}
