@model TentDetailsViewModel
@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = Model.Tent.Name;
    var live  = Model.LiveMetrics.ToList();
    var focus = Model.Alerts.FirstOrDefault();
    var ic    = CultureInfo.InvariantCulture;

    // Farben für Chart.js (überschreiben die ChartSeries-Farben)
    string ClimateColor(string label) => label switch
    {
        "Temperatur"  => "#e05a5a",
        "Luftfeuchte" => "#6b8fe0",
        "VPD"         => "#4ec99a",
        _             => "#aaaaaa"
    };
    string WaterColor(string label) => label switch
    {
        "pH"          => "#f0c040",
        "EC"          => "#e07830",
        "Wassertemp." => "#6b8fe0",
        _             => "#aaaaaa"
    };

    // Daten für Chart.js serialisieren
    static object ToChartPoint(ChartPoint p)
        => new { x = new DateTimeOffset(p.Timestamp.ToUniversalTime()).ToUnixTimeMilliseconds(), y = p.Value };

    var climateLines = (Model.ClimateChart?.Lines ?? new())
        .Where(l => l.Points.Count > 0)
        .Select(l => new { label = l.Label, data = l.Points.OrderBy(p => p.Timestamp).Select(ToChartPoint).ToList() })
        .ToList();

    var waterLines = (Model.WaterChart?.Lines ?? new())
        .Where(l => l.Points.Count > 0 && new[] { "pH", "EC", "Wassertemp." }.Contains(l.Label))
        .Select(l => new { label = l.Label, data = l.Points.OrderBy(p => p.Timestamp).Select(ToChartPoint).ToList() })
        .ToList();

    var climateJson = JsonSerializer.Serialize(climateLines);
    var waterJson   = JsonSerializer.Serialize(waterLines);

    // Mindestens 2 Datenpunkte pro Chart nötig damit Chart.js eine Linie zeichnen kann
    var climatePointCount = climateLines.Sum(l => l.data.Count);
    var waterPointCount   = waterLines.Sum(l => l.data.Count);

    string Fmt(double v, int dec = 1) => v.ToString("F" + dec, ic);
}

<section class="page-hero glass-panel compact-hero tent-dashboard-hero" data-live-tent-endpoint="/api/live/tents/@Model.Tent.Id" data-live-interval-ms="10000">
    <div>
        <span class="eyebrow">@Model.Tent.Kind</span>
        <h1>@Model.Tent.Name</h1>
    </div>
    <div class="hero-actions">
        <a class="btn btn-ghost" asp-controller="Settings" asp-action="Index">Sensoren zuordnen</a>
        <a class="btn btn-primary" asp-controller="Grows" asp-action="Create">Run anlegen</a>
    </div>
</section>

<div class="tent-ops-layout top-gap-lg">
    <section class="content-stack">
        <article class="glass-panel tent-ops-card tent-ops-card--v2">
            <div class="tent-ops-v2">
                <div class="tent-ops-camera-panel">
                    @if (!string.IsNullOrWhiteSpace(Model.Tent.CameraEntityId))
                    {
                        <div style="position:relative; width:100%; aspect-ratio:16/9; overflow:hidden; border-radius:var(--radius-lg);">
                            <img id="cam-buf-a"
                                 style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;transition:opacity 0.3s;opacity:1;"
                                 src="@Url.Action("CameraStream", "Tents", new { id = Model.Tent.Id })"
                                 alt="Live-Kamera @Model.Tent.Name" />
                            <img id="cam-buf-b"
                                 style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;transition:opacity 0.3s;opacity:0;"
                                 alt="" />
                        </div>
                    }
                    else
                    {
                        <div class="ops-card-camera ops-card-camera--placeholder large">
                            <strong>Keine Kamera verknüpft</strong>
                            <p class="muted">Lege eine Kamera-Entity an, damit hier automatisch aktuelle Zeltbilder auftauchen.</p>
                        </div>
                    }
                </div>

                <div class="tent-ops-main-panel">
                    <div class="ops-live-strip">
                        @foreach (var metric in live)
                        {
                            <article class="ops-live-kpi @metric.Tone" data-live-metric data-metric-key="@metric.Key">
                                <span>@metric.Label</span>
                                <strong><span data-live-value>@metric.Value</span><small data-live-unit>@metric.Unit</small></strong>
                                <small class="muted" data-live-hint>@metric.Hint</small>
                            </article>
                        }
                    </div>

                    <div class="chartjs-chart-stack top-gap-sm">

                        @* ── Klima-Chart ─────────────────────────────── *@
                        <div class="glass-panel chartjs-card">
                            <div class="chartjs-card__head">
                                <h3>Klima-Verlauf</h3>
                                <div class="chartjs-range-btns" id="climateRangeBtns">
                                    <button class="chartjs-range-btn is-active" data-range="24">24h</button>
                                    <button class="chartjs-range-btn" data-range="168">7T</button>
                                    <button class="chartjs-range-btn" data-range="336">14T</button>
                                </div>
                            </div>
                            <div class="chartjs-canvas-wrap">
                                @if (climatePointCount >= 2)
                                {
                                    <canvas id="climateChart"></canvas>
                                }
                                else if (climatePointCount == 1)
                                {
                                    <p class="chartjs-no-data">Noch zu wenig Verlaufsdaten – der Chart erscheint sobald mindestens 2 Messungen vorliegen.</p>
                                }
                                else
                                {
                                    <p class="chartjs-no-data">Noch keine Verlaufsdaten</p>
                                }
                            </div>
                            @if (climatePointCount >= 2)
                            {
                                <table class="chartjs-stats">
                                    <thead>
                                        <tr>
                                            <th>Metrik</th>
                                            <th>Min</th>
                                            <th>Max</th>
                                            <th>Ø</th>
                                            <th>Sollbereich</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var line in Model.ClimateChart!.Lines.Where(l => l.Points.Count > 0))
                                        {
                                            var mn   = line.Points.Min(p => p.Value);
                                            var mx   = line.Points.Max(p => p.Value);
                                            var av   = line.Points.Average(p => p.Value);
                                            var soll = line.Label switch
                                            {
                                                "VPD" when Model.VpdTargetMin > 0 => $"{Fmt(Model.VpdTargetMin)}–{Fmt(Model.VpdTargetMax)} kPa",
                                                _ => "–"
                                            };
                                            <tr>
                                                <td><i class="legend-dot" style="background:@ClimateColor(line.Label)"></i>@line.Label</td>
                                                <td>@Fmt(mn)</td>
                                                <td>@Fmt(mx)</td>
                                                <td>@Fmt(av)</td>
                                                <td class="muted">@soll</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>

                        @* ── Reservoir-Chart (nur ActiveHydro) ──────── *@
                        @if (Model.HasHydroGrow && waterLines.Count > 0)
                        {
                            <div class="glass-panel chartjs-card">
                                <div class="chartjs-card__head">
                                    <h3>Wasser / Reservoir</h3>
                                    <div class="chartjs-range-btns" id="waterRangeBtns">
                                        <button class="chartjs-range-btn is-active" data-range="24">24h</button>
                                        <button class="chartjs-range-btn" data-range="168">7T</button>
                                        <button class="chartjs-range-btn" data-range="336">14T</button>
                                    </div>
                                </div>
                                <div class="chartjs-canvas-wrap">
                                    @if (waterPointCount >= 2)
                                    {
                                        <canvas id="waterChart"></canvas>
                                    }
                                    else
                                    {
                                        <p class="chartjs-no-data">Noch zu wenig Verlaufsdaten – der Chart erscheint sobald mindestens 2 Messungen vorliegen.</p>
                                    }
                                </div>
                                <table class="chartjs-stats">
                                    <thead>
                                        <tr>
                                            <th>Metrik</th>
                                            <th>Min</th>
                                            <th>Max</th>
                                            <th>Ø</th>
                                            <th>Sollbereich</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var line in (Model.WaterChart?.Lines ?? new()).Where(l => l.Points.Count > 0 && new[]{"pH","EC","Wassertemp."}.Contains(l.Label)))
                                        {
                                            var mn   = line.Points.Min(p => p.Value);
                                            var mx   = line.Points.Max(p => p.Value);
                                            var av   = line.Points.Average(p => p.Value);
                                            var soll = line.Label switch
                                            {
                                                "pH"          when Model.PhTargetMin > 0          => $"{Fmt(Model.PhTargetMin, 2)}–{Fmt(Model.PhTargetMax, 2)}",
                                                "EC"          when Model.EcTargetMin > 0          => $"{Fmt(Model.EcTargetMin, 2)}–{Fmt(Model.EcTargetMax, 2)} mS/cm",
                                                "Wassertemp." when Model.WaterTempTargetMin > 0   => $"{Fmt(Model.WaterTempTargetMin, 0)}–{Fmt(Model.WaterTempTargetMax, 0)} °C",
                                                _ => "–"
                                            };
                                            <tr>
                                                <td><i class="legend-dot" style="background:@WaterColor(line.Label)"></i>@line.Label</td>
                                                <td>@Fmt(mn, 2)</td>
                                                <td>@Fmt(mx, 2)</td>
                                                <td>@Fmt(av, 2)</td>
                                                <td class="muted">@soll</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                    </div>

                    <article class="ops-focus-inline ops-focus-inline--full top-gap-sm">
                        <span class="kicker-label">Nächster Fokus</span>
                        @if (focus is not null)
                        {
                            <strong>@focus.Title</strong>
                            <p class="muted">@focus.Message</p>
                        }
                        else
                        {
                            <strong>Keine akuten Auffälligkeiten</strong>
                            <p class="muted">Dieses Zelt wirkt aktuell ruhig. Nutze die Runs unten für Aufgaben, Bilder und die jeweilige Grow-Logik.</p>
                        }
                    </article>
                </div>
            </div>
        </article>

        <section class="section-header top-gap-lg">
            <div>
                <span class="kicker-label">Aktive Runs</span>
                <h2>Was aktuell in diesem Zelt läuft</h2>
                <p class="muted">Öffne einen Run für Bild, letzte Messung, Aufgaben und die passende Template-Logik.</p>
            </div>
        </section>
        <div class="card-grid two-up">
            @foreach (var grow in Model.ActiveGrows)
            {
                @await Html.PartialAsync("_GrowCard", grow)
            }
        </div>
    </section>

    @section Scripts {
    <script>
    // Kamera-Livestream: Double-Buffer, kein Flackern
    (function () {
        var bufA = document.getElementById('cam-buf-a');
        var bufB = document.getElementById('cam-buf-b');
        if (!bufA || !bufB) return;
        var active = bufA;
        var tentId = @Model.Tent.Id;
        setInterval(function () {
            var next = active === bufA ? bufB : bufA;
            next.onload = function () {
                active.style.opacity = '0';
                next.style.opacity = '1';
                active = next;
            };
            next.onerror = function () { /* behalte altes Bild */ };
            next.src = '/tents/' + tentId + '/camera-stream?t=' + Date.now();
        }, 3000);
    }());
    </script>
    <script>
    (function () {
        'use strict';

        // ── Hilfsfunktionen ────────────────────────────────────────────
        function fmtTs(ms) {
            var d = new Date(ms);
            return d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' })
                + ' '
                + d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
        }

        var chartDefaults = {
            responsive: true,
            maintainAspectRatio: true,
            aspectRatio: 2.6,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    display: true,
                    labels: {
                        color: '#9bb4ac',
                        usePointStyle: true,
                        filter: function (item) { return !item.text.startsWith('_'); }
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(10,17,16,0.94)',
                    borderColor: 'rgba(132,164,151,0.18)',
                    borderWidth: 1,
                    titleColor: '#edf8f4',
                    bodyColor: '#9bb4ac'
                }
            }
        };

        function xScale() {
            return {
                type: 'linear',
                ticks: {
                    color: '#9bb4ac',
                    maxTicksLimit: 7,
                    callback: function (v) { return fmtTs(v); }
                },
                grid: { color: 'rgba(132,164,151,0.07)' }
            };
        }

        function yScale(label, color, right, sugMin, sugMax) {
            var s = {
                type: 'linear',
                position: right ? 'right' : 'left',
                ticks: { color: color || '#9bb4ac' },
                grid: right ? { drawOnChartArea: false } : { color: 'rgba(132,164,151,0.07)' },
                title: { display: true, text: label, color: color || '#9bb4ac', font: { size: 11 } }
            };
            if (sugMin !== undefined) s.suggestedMin = sugMin;
            if (sugMax !== undefined) s.suggestedMax = sugMax;
            return s;
        }

        function applyRange(chart, allDatasets, hours) {
            var cutoff = Date.now() - hours * 3600000;
            chart.data.datasets.forEach(function (ds, i) {
                if (allDatasets[i]._isTarget) return;
                ds.data = allDatasets[i].data.filter(function (p) { return p.x >= cutoff; });
            });
            chart.update();
        }

        function wireRangeButtons(containerId, chart, allDatasets) {
            var btns = document.querySelectorAll('#' + containerId + ' .chartjs-range-btn');
            // initialen 24h-Filter aus dem aktiven Button anwenden
            var activeBtn = document.querySelector('#' + containerId + ' .chartjs-range-btn.is-active');
            if (activeBtn) { applyRange(chart, allDatasets, parseInt(activeBtn.dataset.range, 10)); }
            btns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    btns.forEach(function (b) { b.classList.remove('is-active'); });
                    btn.classList.add('is-active');
                    applyRange(chart, allDatasets, parseInt(btn.dataset.range, 10));
                });
            });
        }

        // ── Klima-Chart ────────────────────────────────────────────────
        (function buildClimateChart() {
            var canvas = document.getElementById('climateChart');
            if (!canvas) return;

            var raw = @Html.Raw(climateJson);
            var vpdMin = @(Model.VpdTargetMin.ToString("0.0##", ic));
            var vpdMax = @(Model.VpdTargetMax.ToString("0.0##", ic));

            var colorMap = { 'Temperatur': '#e05a5a', 'Luftfeuchte': '#6b8fe0', 'VPD': '#4ec99a' };

            var allDatasets = raw.map(function (s) {
                return {
                    label: s.label,
                    data: s.data,
                    borderColor: colorMap[s.label] || '#aaa',
                    backgroundColor: (colorMap[s.label] || '#aaa') + '18',
                    yAxisID: s.label === 'VPD' ? 'y1' : 'y',
                    tension: 0.3,
                    pointRadius: 0,
                    pointHoverRadius: 4,
                    borderWidth: 1.5,
                    fill: false
                };
            });

            // VPD Sollbereich als gestrichelte Linien
            if (vpdMin > 0) {
                var far = 30 * 24 * 3600000;
                var now = Date.now();
                allDatasets.push({ _isTarget: true, label: 'VPD Soll Min', data: [{x: now - far, y: vpdMin}, {x: now + far, y: vpdMin}], borderColor: 'rgba(78,201,154,0.4)', borderDash: [6, 4], pointRadius: 0, borderWidth: 1.5, yAxisID: 'y1', fill: false });
                allDatasets.push({ _isTarget: true, label: '_vpd_max',     data: [{x: now - far, y: vpdMax}, {x: now + far, y: vpdMax}], borderColor: 'rgba(78,201,154,0.4)', borderDash: [6, 4], pointRadius: 0, borderWidth: 1.5, yAxisID: 'y1', fill: false });
            }

            var chart = new Chart(canvas, {
                type: 'line',
                data: { datasets: allDatasets.map(function (d) { return Object.assign({}, d, { data: d.data.slice() }); }) },
                options: Object.assign({}, chartDefaults, {
                    scales: {
                        x:  xScale(),
                        y:  yScale('°C / %', '#9bb4ac', false, 15, 40),
                        y1: yScale('kPa', '#4ec99a', true, 0, 2.5)
                    }
                })
            });

            wireRangeButtons('climateRangeBtns', chart, allDatasets);
        }());

        // ── Reservoir-Chart ────────────────────────────────────────────
        (function buildWaterChart() {
            var canvas = document.getElementById('waterChart');
            if (!canvas) return;

            var raw = @Html.Raw(waterJson);
            var phMin  = @(Model.PhTargetMin.ToString("0.0##", ic));
            var phMax  = @(Model.PhTargetMax.ToString("0.0##", ic));
            var ecMin  = @(Model.EcTargetMin.ToString("0.0##", ic));
            var ecMax  = @(Model.EcTargetMax.ToString("0.0##", ic));

            var colorMap = { 'pH': '#f0c040', 'EC': '#e07830', 'Wassertemp.': '#6b8fe0' };

            var allDatasets = raw.map(function (s) {
                return {
                    label: s.label,
                    data: s.data,
                    borderColor: colorMap[s.label] || '#aaa',
                    backgroundColor: (colorMap[s.label] || '#aaa') + '18',
                    yAxisID: (s.label === 'Wassertemp.') ? 'y1' : 'y',
                    tension: 0.3,
                    pointRadius: 0,
                    pointHoverRadius: 4,
                    borderWidth: 1.5,
                    fill: false
                };
            });

            // pH und EC Sollbereiche
            var far = 30 * 24 * 3600000;
            var now = Date.now();
            function targetLine(label, y, color) {
                return { _isTarget: true, label: label, data: [{x: now - far, y: y}, {x: now + far, y: y}], borderColor: color, borderDash: [6, 4], pointRadius: 0, borderWidth: 1.5, yAxisID: 'y', fill: false };
            }
            if (phMin > 0) { allDatasets.push(targetLine('pH Soll Min', phMin, 'rgba(240,192,64,0.4)')); allDatasets.push(targetLine('_ph_max', phMax, 'rgba(240,192,64,0.4)')); }
            if (ecMin > 0) { allDatasets.push(targetLine('EC Soll Min', ecMin, 'rgba(224,120,48,0.4)')); allDatasets.push(targetLine('_ec_max', ecMax, 'rgba(224,120,48,0.4)')); }

            var chart = new Chart(canvas, {
                type: 'line',
                data: { datasets: allDatasets.map(function (d) { return Object.assign({}, d, { data: d.data.slice() }); }) },
                options: Object.assign({}, chartDefaults, {
                    scales: {
                        x:  xScale(),
                        y:  yScale('pH / EC', '#9bb4ac', false, 4, 8),
                        y1: yScale('°C', '#6b8fe0', true, 15, 30)
                    }
                })
            });

            wireRangeButtons('waterRangeBtns', chart, allDatasets);
        }());

    }());
    </script>
    }

    <aside class="sidebar-stack">
        <article class="glass-panel side-card">
            <h3>Home Assistant</h3>
            <p class="muted">@(Model.HomeAssistant.IsConfigured ? "Verbindung aktiv. Mapping und Tokens verwaltest du zentral in den Einstellungen." : "Noch keine Verbindung eingerichtet. Hinterlege zuerst URL, Token und Entity-IDs.")</p>
            <a class="btn btn-ghost full-width" asp-controller="Settings" asp-action="Index">Zu den Einstellungen</a>
        </article>
        <article class="glass-panel side-card">
            <h3>Zelt-Setup</h3>
            <ul class="clean-list compact-list">
                <li><strong>Typ:</strong> @Model.Tent.Kind</li>
                <li><strong>Temperatur:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.TemperatureEntityId) ? "offen" : Model.Tent.TemperatureEntityId)</li>
                <li><strong>Feuchte:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.HumidityEntityId) ? "offen" : Model.Tent.HumidityEntityId)</li>
                <li><strong>VPD:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.VpdEntityId) ? "offen" : Model.Tent.VpdEntityId)</li>
                <li><strong>Lichtzyklus:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.LightCycle) ? "offen" : Model.Tent.LightCycle)</li>
                <li><strong>PPFD:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.PpfdTarget) ? (string.IsNullOrWhiteSpace(Model.Tent.PpfdEntityId) ? "offen" : "über Sensor") : Model.Tent.PpfdTarget + " µmol/m²/s")</li>
                <li><strong>PPFD Entity:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.PpfdEntityId) ? "offen" : Model.Tent.PpfdEntityId)</li>
                <li><strong>Kamera:</strong> @(string.IsNullOrWhiteSpace(Model.Tent.CameraEntityId) ? "offen" : Model.Tent.CameraEntityId)</li>
            </ul>
        </article>
    </aside>
</div>
