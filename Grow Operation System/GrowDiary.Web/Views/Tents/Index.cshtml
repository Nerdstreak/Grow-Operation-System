@model TentIndexViewModel
@{
    ViewData["Title"] = "Zelte";
    var selected = Model.SelectedCard;
    var hasMultipleTents = Model.Cards.Count > 1;
    var previewFocus = selected?.Alerts.FirstOrDefault();

    string SetupValue(string? value, string fallback = "offen")
        => string.IsNullOrWhiteSpace(value) ? fallback : value;
}

<section class="glass-panel tents-page-topbar">
    <div>
        <span class="eyebrow">Zelte</span>
        <h1>Zelte</h1>
        @if (Model.Cards.Any())
        {
            <p class="muted">@Model.Cards.Count aktive @(Model.Cards.Count == 1 ? "Umgebung" : "Umgebungen")</p>
        }
    </div>
    <div class="hero-actions">
        <a class="btn btn-ghost" asp-controller="Settings" asp-action="Index">Sensorik</a>
        <a class="btn btn-primary" asp-controller="Grows" asp-action="Create">Run anlegen</a>
    </div>
</section>

@if (!Model.Cards.Any())
{
    <div class="top-gap-lg">
        <article class="glass-panel empty-state-card empty-state-card--tents">
            <span class="eyebrow">Keine aktiven Zelte</span>
            <strong>Es ist aktuell kein Zelt belegt</strong>
            <p class="muted">Sobald ein Grow auf Planning oder Running steht und einem Zelt zugeordnet ist, erscheint es hier automatisch.</p>
        </article>
    </div>
}
else if (selected is not null)
{
    <div class="@(hasMultipleTents ? "tents-master-layout" : "tents-single-layout") top-gap-lg" data-live-home-endpoint="/api/live/home" data-live-interval-ms="10000">
        @if (hasMultipleTents)
        {
            <aside class="glass-panel tents-selector-panel">
                <div class="section-header tents-selector-panel__head">
                    <div>
                        <span class="kicker-label">Zelte</span>
                        <h2>Auswahl</h2>
                    </div>
                </div>

                <div class="tents-selector-list">
                    @foreach (var card in Model.Cards)
                    {
                        var isActive = Model.SelectedTentId == card.Tent.Id;
                        var overviewMetrics = card.LiveMetrics.Take(4).ToList();
                        var focus = card.Alerts.FirstOrDefault();

                        <article class="tent-selector-card @(isActive ? "is-active" : string.Empty)" data-live-tent-card data-tent-id="@card.Tent.Id">
                            <div class="tent-selector-card__head">
                                <div>
                                    <div class="ops-card-meta">
                                        <span class="eyebrow">@card.Tent.Kind</span>
                                        @if (isActive)
                                        {
                                            <span class="detail-pill detail-pill--info">Aktiv</span>
                                        }
                                    </div>
                                    <h3>@card.Tent.Name</h3>
                                    <p class="muted">@card.Tent.ActiveGrowCount aktive Runs</p>
                                </div>
                                <a class="btn btn-ghost" asp-action="Index" asp-route-selected="@card.Tent.Id">Ansehen</a>
                            </div>

                            <div class="ops-live-strip ops-live-strip--selector">
                                @foreach (var metric in overviewMetrics)
                                {
                                    <article class="ops-live-kpi @metric.Tone" data-live-metric data-metric-key="@metric.Key">
                                        <span>@metric.Label</span>
                                        <strong><span data-live-value>@metric.Value</span><small data-live-unit>@metric.Unit</small></strong>
                                        <small class="muted" data-live-hint>@metric.Hint</small>
                                    </article>
                                }
                            </div>

                            <div class="tent-selector-card__footer">
                                @if (focus is not null)
                                {
                                    <div class="tent-selector-card__focus">
                                        <span class="eyebrow">Fokus</span>
                                        <strong>@focus.Title</strong>
                                    </div>
                                }
                                else
                                {
                                    <div class="tent-selector-card__focus">
                                        <span class="eyebrow">Status</span>
                                        <strong>Stabil</strong>
                                    </div>
                                }

                                <a class="btn btn-primary" asp-action="Details" asp-route-id="@card.Tent.Id">Dashboard</a>
                            </div>
                        </article>
                    }
                </div>
            </aside>
        }

        <section class="content-stack tents-detail-stack">
            <article class="glass-panel tents-selected-bar">
                <div>
                    <div class="ops-card-meta">
                        <span class="eyebrow">@selected.Tent.Kind</span>
                        @if (hasMultipleTents)
                        {
                            <span class="detail-pill detail-pill--info">Ausgewählt</span>
                        }
                    </div>
                    <h2>@selected.Tent.Name</h2>
                </div>
                <div class="row-actions">
                    <a class="btn btn-ghost" asp-action="Details" asp-route-id="@selected.Tent.Id">Vollansicht</a>
                </div>
            </article>

            <div class="detail-layout detail-layout--ops tents-detail-layout">
                <section class="content-stack">
                    <article class="glass-panel tent-ops-card tent-ops-card--v2" data-live-tent-card data-tent-id="@selected.Tent.Id">
                        <div class="tent-ops-v2">
                            <div class="tent-ops-camera-panel">
                                @if (Model.HomeAssistantConfigured && !string.IsNullOrWhiteSpace(selected.Tent.CameraEntityId))
                                {
                                    <img class="camera-preview camera-preview--large" data-live-camera-thumb src="@Url.Action("CameraSnapshot", "Tents", new { id = selected.Tent.Id, t = DateTimeOffset.UtcNow.ToUnixTimeSeconds() })" alt="Kamera @selected.Tent.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="ops-card-camera ops-card-camera--placeholder large">
                                        <strong>Keine Kamera verknüpft</strong>
                                        <p class="muted">Lege eine Kamera-Entity an, damit hier aktuelle Zeltbilder auftauchen.</p>
                                    </div>
                                }
                            </div>

                            <div class="tent-ops-main-panel">
                                <div class="ops-live-strip">
                                    @foreach (var metric in selected.LiveMetrics.Take(5))
                                    {
                                        <article class="ops-live-kpi @metric.Tone" data-live-metric data-metric-key="@metric.Key">
                                            <span>@metric.Label</span>
                                            <strong><span data-live-value>@metric.Value</span><small data-live-unit>@metric.Unit</small></strong>
                                            <small class="muted" data-live-hint>@metric.Hint</small>
                                        </article>
                                    }
                                </div>

                                <div class="ops-chart-grid ops-chart-grid--single top-gap-sm">
                                    @if (selected.ClimateSparkline is not null)
                                    {
                                        @await Html.PartialAsync("_OpsChartCard", selected.ClimateSparkline)
                                    }
                                    @if (selected.WaterSparkline is not null)
                                    {
                                        @await Html.PartialAsync("_OpsChartCard", selected.WaterSparkline)
                                    }
                                </div>

                                <article class="ops-focus-inline ops-focus-inline--full top-gap-sm">
                                    <span class="kicker-label">Fokus</span>
                                    @if (previewFocus is not null)
                                    {
                                        <strong>@previewFocus.Title</strong>
                                        <p class="muted">@previewFocus.Message</p>
                                    }
                                    else
                                    {
                                        <strong>Keine akuten Auffälligkeiten</strong>
                                        <p class="muted">Nutze die Runs unten für Aufgaben, Fotos und den jeweiligen Verlauf.</p>
                                    }
                                </article>
                            </div>
                        </div>
                    </article>

                    <section class="section-header tents-runs-header">
                        <div>
                            <span class="kicker-label">Aktive Runs</span>
                            <h3>Im Zelt</h3>
                        </div>
                    </section>

                    @if (selected.Tent.ActiveGrows.Any())
                    {
                        <div class="card-grid @(selected.Tent.ActiveGrows.Count > 1 ? "two-up" : string.Empty)">
                            @foreach (var grow in selected.Tent.ActiveGrows)
                            {
                                @await Html.PartialAsync("_GrowCard", grow)
                            }
                        </div>
                    }
                    else
                    {
                        <article class="glass-panel empty-state-card empty-state-card--inline empty-state-card--runs">
                            <strong>Kein aktiver Run</strong>
                            <p class="muted">Lege einen Run an oder ordne einen bestehenden Grow diesem Zelt zu.</p>
                        </article>
                    }
                </section>

                <aside class="sidebar-stack">
                    <article class="glass-panel side-card">
                        <h3>Home Assistant</h3>
                        <p class="muted">@(Model.HomeAssistantConfigured ? "Verbindung aktiv. Mapping und Tokens verwaltest du zentral in den Einstellungen." : "Noch keine Verbindung eingerichtet. Hinterlege zuerst URL, Token und Entity-IDs.")</p>
                        <a class="btn btn-ghost full-width" asp-controller="Settings" asp-action="Index">Zu den Einstellungen</a>
                    </article>
                    <article class="glass-panel side-card">
                        <h3>Zelt-Setup</h3>
                        <ul class="clean-list compact-list">
                            <li><strong>Typ:</strong> @selected.Tent.Kind</li>
                            <li><strong>Lichtzyklus:</strong> @SetupValue(selected.Tent.LightCycle, "nicht gesetzt")</li>
                            <li><strong>PPFD:</strong> @SetupValue(selected.Tent.PpfdTarget, string.IsNullOrWhiteSpace(selected.Tent.PpfdEntityId) ? "nicht gesetzt" : "über Sensor")</li>
                            <li><strong>Temperatur:</strong> @SetupValue(selected.Tent.TemperatureEntityId)</li>
                            <li><strong>Feuchte:</strong> @SetupValue(selected.Tent.HumidityEntityId)</li>
                            <li><strong>VPD:</strong> @SetupValue(selected.Tent.VpdEntityId)</li>
                            <li><strong>Kamera:</strong> @SetupValue(selected.Tent.CameraEntityId)</li>
                        </ul>
                    </article>
                </aside>
            </div>
        </section>
    </div>
}
