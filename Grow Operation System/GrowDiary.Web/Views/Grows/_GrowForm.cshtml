@model GrowFormViewModel
@{
    var isEdit = Model.Id.HasValue;
}
<form method="post" class="form-shell wizard-shell" data-grow-wizard>
    <input type="hidden" asp-for="TemplateId" />
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    @* Feste Werte: RDWC/DWC-only App *@
    <input type="hidden" name="MediumType" value="Hydro" />
    <input type="hidden" name="FeedingStyle" value="None" />
    <input type="hidden" name="IrrigationType" value="ActiveHydro" />
    <input type="hidden" asp-for="Status" />
    <input type="hidden" asp-for="Environment" />

    @if (Model.TemplateId.HasValue)
    {
        <div class="inline-banner">Template #@Model.TemplateId wurde angewendet. Prüfe alle Felder vor dem Speichern.</div>
    }

    <div class="wizard-layout">
        <div class="wizard-stepper">
            <div class="wizard-step-item">
                <div class="step-circle is-active" data-step-target="step-genetik">1</div>
                <div class="step-text"><strong>Genetik</strong><span>Sorte &amp; Material</span></div>
            </div>
            <div class="wizard-step-connector"></div>
            <div class="wizard-step-item">
                <div class="step-circle" data-step-target="step-system">2</div>
                <div class="step-text"><strong>System</strong><span>RDWC / DWC</span></div>
            </div>
            <div class="wizard-step-connector"></div>
            <div class="wizard-step-item">
                <div class="step-circle" data-step-target="step-naehrstoffe">3</div>
                <div class="step-text"><strong>Nährstoffe</strong><span>Wasser &amp; Linie</span></div>
            </div>
            <div class="wizard-step-connector"></div>
            <div class="wizard-step-item" style="flex:none">
                <div class="step-circle" data-step-target="step-einstieg">4</div>
                <div class="step-text"><strong>Einstieg</strong><span>Phase &amp; Datum</span></div>
            </div>
        </div>

        <div class="wizard-content">

            @* Schritt 1: Genetik *@
            <section class="wizard-panel is-active" data-step-panel="step-genetik">
                <div class="section-header compact">
                    <div>
                        <span class="kicker-label">Schritt 1</span>
                        <h2>Genetik</h2>
                    </div>
                </div>
                <div class="form-grid two top-gap-sm">
                    <div class="field"><label asp-for="Name">Name des Grows / der Pflanze</label><input asp-for="Name" /></div>
                    <div class="field"><label asp-for="TentId">Zelt</label><select asp-for="TentId" asp-items="Model.TentOptions"><option value="">Ohne Zuordnung</option></select></div>
                    <div class="field"><label asp-for="Strain">Sorte</label><input asp-for="Strain" placeholder="z. B. Purple Lemonade" /></div>
                    <div class="field"><label asp-for="Breeder">Seed Brand / Breeder</label><input asp-for="Breeder" placeholder="z. B. FastBuds" /></div>
                    <div class="field"><label asp-for="PhenoNumber">Pheno-Nummer (optional)</label><input asp-for="PhenoNumber" type="number" min="1" placeholder="z. B. 3 für #3" /></div>
                </div>

                <fieldset class="form-fieldset top-gap-sm">
                    <legend>Samentyp</legend>
                    <div class="btn-group-radio" id="seed-type-group">
                        <label class="btn-radio @(Model.SeedType == SeedType.Feminized ? "is-active" : "")">
                            <input type="radio" name="SeedType" value="Feminized" @(Model.SeedType == SeedType.Feminized ? "checked" : "") /> Feminisiert
                        </label>
                        <label class="btn-radio @(Model.SeedType == SeedType.Autoflower ? "is-active" : "")">
                            <input type="radio" name="SeedType" value="Autoflower" @(Model.SeedType == SeedType.Autoflower ? "checked" : "") /> Autoflower
                        </label>
                        <label class="btn-radio @(Model.SeedType == SeedType.Regular ? "is-active" : "")">
                            <input type="radio" name="SeedType" value="Regular" @(Model.SeedType == SeedType.Regular ? "checked" : "") /> Regular
                        </label>
                    </div>
                </fieldset>

                <div id="breeder-weeks-row" class="form-grid two top-gap-sm" style="@(Model.IsAutoflower ? "display:none;" : "")">
                    <div class="field">
                        <label>Breeder Blütezeit (Wochen)</label>
                        <div class="field-row">
                            <input asp-for="BreederFlowerWeeksMin" type="number" min="1" max="30" placeholder="Min" />
                            <span class="field-sep">–</span>
                            <input asp-for="BreederFlowerWeeksMax" type="number" min="1" max="30" placeholder="Max" />
                        </div>
                    </div>
                </div>

                <fieldset class="form-fieldset top-gap-sm">
                    <legend>Startmaterial</legend>
                    <div class="btn-group-radio" id="start-material-group">
                        <label class="btn-radio @(Model.StartMaterial == StartMaterial.Seed ? "is-active" : "")">
                            <input type="radio" name="StartMaterial" value="Seed" @(Model.StartMaterial == StartMaterial.Seed ? "checked" : "") /> Samen
                        </label>
                        <label class="btn-radio @(Model.StartMaterial == StartMaterial.Clone ? "is-active" : "")">
                            <input type="radio" name="StartMaterial" value="Clone" @(Model.StartMaterial == StartMaterial.Clone ? "checked" : "") /> Steckling
                        </label>
                    </div>
                </fieldset>

                <div id="germination-row" class="form-grid two top-gap-sm" style="@(Model.StartMaterial != StartMaterial.Seed ? "display:none;" : "")">
                    <div class="field">
                        <label asp-for="GerminationMethod">Keimmethode</label>
                        <select asp-for="GerminationMethod">
                            <option value="">Nicht angegeben</option>
                            <option value="PaperTowel">Papierhandtuch</option>
                            <option value="Rockwool">Rockwool</option>
                            <option value="RapidRooter">Rapid Rooter</option>
                            <option value="DirectInSystem">Direkt ins System</option>
                        </select>
                    </div>
                </div>

                <div id="clone-row" class="form-grid two top-gap-sm" style="@(Model.StartMaterial != StartMaterial.Clone ? "display:none;" : "")">
                    <div class="field"><label asp-for="CloneSource">Herkunft des Stecklings</label><input asp-for="CloneSource" placeholder="z. B. Mutterpflanze #2, befreundeter Grower" /></div>
                    <div class="field">
                        <label class="checkbox-field" style="margin-top: 28px;">
                            <input type="hidden" name="CloneIsRooted" value="false" />
                            <input type="checkbox" asp-for="CloneIsRooted" value="true" />
                            <span>Bereits bewurzelt</span>
                        </label>
                    </div>
                </div>
            </section>

            @* Schritt 2: System *@
            <section class="wizard-panel" data-step-panel="step-system">
                <div class="section-header compact">
                    <div>
                        <span class="kicker-label">Schritt 2</span>
                        <h2>System</h2>
                    </div>
                </div>

                <fieldset class="form-fieldset top-gap-sm">
                    <legend>Hydro-Untertyp</legend>
                    <div class="btn-group-radio" id="hydro-style-group">
                        <label class="btn-radio btn-radio--large @(Model.HydroStyle == HydroStyle.RDWC ? "is-active" : "")">
                            <input type="radio" name="HydroStyle" value="RDWC" @(Model.HydroStyle == HydroStyle.RDWC ? "checked" : "") />
                            <strong>RDWC</strong>
                            <small>Rezirkulierend, mehrere Eimer</small>
                        </label>
                        <label class="btn-radio btn-radio--large @(Model.HydroStyle == HydroStyle.DWC ? "is-active" : "")">
                            <input type="radio" name="HydroStyle" value="DWC" @(Model.HydroStyle == HydroStyle.DWC ? "checked" : "") />
                            <strong>DWC</strong>
                            <small>Einzelner Behälter pro Pflanze</small>
                        </label>
                    </div>
                </fieldset>

                <div class="form-grid two top-gap-sm">
                    <div class="field"><label asp-for="PlantCount">Anzahl Pflanzen / Eimer</label><input asp-for="PlantCount" type="number" min="1" placeholder="z. B. 4" /></div>
                    <div class="field"><label asp-for="ReservoirSize">Reservoirgröße</label><input asp-for="ReservoirSize" placeholder="z. B. 60 L, 4 × 15 L" /></div>
                    <div class="field"><label asp-for="ContainerSize">Netztopf-Größe</label><input asp-for="ContainerSize" placeholder="z. B. 15 cm, 6-Zoll" /></div>
                    <div class="field">
                        <label asp-for="PropagationMedium">Anzuchtmedium</label>
                        <select asp-for="PropagationMedium">
                            <option value="">Nicht angegeben</option>
                            <option value="Rockwool">Rockwool</option>
                            <option value="Hydroton">Hydroton</option>
                            <option value="RapidRooter">Rapid Rooter</option>
                            <option value="Neoprene">Neoprene</option>
                        </select>
                    </div>
                    <div class="field"><label asp-for="Light">Licht</label><input asp-for="Light" placeholder="z. B. AC Infinity 300W, Spider Farmer SE5000" /></div>
                    <div class="field">
                        <label class="checkbox-field" style="margin-top: 28px;">
                            <input type="hidden" name="HasChiller" value="false" />
                            <input type="checkbox" asp-for="HasChiller" value="true" />
                            <span>Chiller vorhanden</span>
                        </label>
                    </div>
                </div>
            </section>

            @* Schritt 3: Nährstoffe & Wasser *@
            <section class="wizard-panel" data-step-panel="step-naehrstoffe">
                <div class="section-header compact">
                    <div>
                        <span class="kicker-label">Schritt 3</span>
                        <h2>Nährstoffe & Wasser</h2>
                    </div>
                </div>

                <fieldset class="form-fieldset top-gap-sm">
                    <legend>Wasserquelle</legend>
                    <div class="btn-group-radio" id="water-source-group">
                        <label class="btn-radio @(Model.WaterSource == WaterSource.RO ? "is-active" : "")">
                            <input type="radio" name="WaterSource" value="RO" @(Model.WaterSource == WaterSource.RO ? "checked" : "") /> RO-Wasser
                        </label>
                        <label class="btn-radio @(Model.WaterSource == WaterSource.Tap ? "is-active" : "")">
                            <input type="radio" name="WaterSource" value="Tap" @(Model.WaterSource == WaterSource.Tap ? "checked" : "") /> Leitungswasser
                        </label>
                        <label class="btn-radio @(Model.WaterSource == WaterSource.Mixed ? "is-active" : "")">
                            <input type="radio" name="WaterSource" value="Mixed" @(Model.WaterSource == WaterSource.Mixed ? "checked" : "") /> Gemischt
                        </label>
                    </div>
                </fieldset>

                <div class="form-grid one top-gap-sm">
                    <div class="field full">
                        <label asp-for="Nutrients">Nährstofflinie</label>
                        <input asp-for="Nutrients" list="nutrientSuggestions" placeholder="z. B. Athena Blended, Canna Aqua, GHF" />
                        <datalist id="nutrientSuggestions">
                            @foreach (var suggestion in Model.NutrientSuggestions)
                            {
                                <option value="@suggestion"></option>
                            }
                        </datalist>
                    </div>
                </div>
            </section>

            @* Schritt 4: Einstiegspunkt *@
            <section class="wizard-panel" data-step-panel="step-einstieg">
                <div class="section-header compact">
                    <div>
                        <span class="kicker-label">Schritt 4</span>
                        <h2>Einstiegspunkt</h2>
                    </div>
                </div>
                <div class="form-grid two top-gap-sm">
                    <div class="field"><label asp-for="StartDate">Startdatum</label><input asp-for="StartDate" type="date" /></div>
                </div>

                <fieldset class="form-fieldset top-gap-sm">
                    <legend>Einstiegspunkt</legend>
                    <div class="btn-group-radio" id="entry-point-group">
                        <label class="btn-radio @(Model.EntryPoint == GrowEntryPoint.Germination ? "is-active" : "")" data-entry-for="Seed">
                            <input type="radio" name="EntryPoint" value="Germination" @(Model.EntryPoint == GrowEntryPoint.Germination ? "checked" : "") /> Keimung
                        </label>
                        <label class="btn-radio @(Model.EntryPoint == GrowEntryPoint.Seedling ? "is-active" : "")" data-entry-for="Seed">
                            <input type="radio" name="EntryPoint" value="Seedling" @(Model.EntryPoint == GrowEntryPoint.Seedling ? "checked" : "") /> Anzucht
                        </label>
                        <label class="btn-radio @(Model.EntryPoint == GrowEntryPoint.Veg ? "is-active" : "")" data-entry-for="Seed Clone">
                            <input type="radio" name="EntryPoint" value="Veg" @(Model.EntryPoint == GrowEntryPoint.Veg ? "checked" : "") /> Veg
                        </label>
                        <label class="btn-radio @(Model.EntryPoint == GrowEntryPoint.Flower ? "is-active" : "")" data-entry-for="Seed Clone">
                            <input type="radio" name="EntryPoint" value="Flower" @(Model.EntryPoint == GrowEntryPoint.Flower ? "checked" : "") /> Blüte
                        </label>
                        <label class="btn-radio @(Model.EntryPoint == GrowEntryPoint.Flush ? "is-active" : "")" data-entry-for="Seed Clone">
                            <input type="radio" name="EntryPoint" value="Flush" @(Model.EntryPoint == GrowEntryPoint.Flush ? "checked" : "") /> Flush
                        </label>
                    </div>
                </fieldset>

                @* Tage in Phase – Photoperiod + nicht Keimung *@
                <div id="days-in-phase-row" class="form-grid two top-gap-sm" style="@(!Model.NeedsDaysInPhase ? "display:none;" : "")">
                    <div class="field">
                        <label asp-for="DaysAlreadyInPhase">Tage bereits in dieser Phase</label>
                        <input asp-for="DaysAlreadyInPhase" type="number" min="0" placeholder="z. B. 14" />
                    </div>
                </div>

                @* Autoflower: Tage seit Keimung *@
                <div id="autoflower-days-row" class="form-grid two top-gap-sm" style="@(!Model.IsAutoflower ? "display:none;" : "")">
                    <div class="field">
                        <label asp-for="AutoflowerDaysSinceGermination">Tage seit Keimung (gesamt)</label>
                        <input asp-for="AutoflowerDaysSinceGermination" type="number" min="0" placeholder="z. B. 35" />
                    </div>
                </div>

                @* Flip-Datum – Photoperiod + Blüte *@
                <div id="flip-date-row" class="form-grid two top-gap-sm" style="@(!Model.NeedsFlipDate ? "display:none;" : "")">
                    <div class="field">
                        <label asp-for="FlipDate">Flip-Datum (12/12)</label>
                        <input asp-for="FlipDate" type="date" />
                    </div>
                </div>

                <div class="form-grid one top-gap-sm">
                    <div class="field full"><label asp-for="Notes">Notizen zum Run</label><textarea asp-for="Notes" rows="4" placeholder="z. B. Zielwerte, Besonderheiten, geplante Methoden"></textarea></div>
                </div>
            </section>

            <div class="wizard-actions">
                <button type="button" class="btn btn-ghost" data-step-prev>Zurück</button>
                <div class="row-actions">
                    <a class="btn btn-ghost" asp-controller="Grows" asp-action="@(isEdit ? "Details" : "Index")" asp-route-id="@Model.Id">Abbrechen</a>
                    @if (isEdit)
                    {
                        <button class="btn btn-danger" type="submit" formaction="@Url.Action("Delete", "Grows", new { id = Model.Id })" formmethod="post" onclick="return confirm('Grow wirklich löschen?');">Grow löschen</button>
                    }
                    <button type="button" class="btn btn-primary" data-step-next>Weiter</button>
                    <button class="btn btn-primary wizard-submit" type="submit">@(isEdit ? "Änderungen speichern" : "Grow anlegen")</button>
                </div>
            </div>
        </div>
    </div>
</form>
