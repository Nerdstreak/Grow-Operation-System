@* ─────────────────────────────────────────────────────────────
   Home.razor  (Page)
   Route: /
   Ersetzt: Home/Index.cshtml
   ───────────────────────────────────────────────────────────── *@
@page "/"
@inject GrowDashboardComposer Composer
@inject TaskRepository TaskRepo
@implements IDisposable

@* Topbar *@
<div class="topbar">
    <span class="topbar-title">Operations</span>
    <div class="topbar-right">
        <button class="btn" @onclick="Refresh">Aktualisieren</button>
    </div>
</div>

@* Alert Bar – nur bei kritischen Abweichungen *@
@if (_criticalItems.Any())
{
    <div class="alert-bar">
        <div class="alert-dot"></div>
        <strong>@_criticalItems[0].Location – @_criticalItems[0].Title</strong>
        <span>@_criticalItems[0].Body</span>
        @if (_criticalItems.Count > 1)
        {
            <span class="alert-bar-more">+@(_criticalItems.Count - 1) weitere →</span>
        }
    </div>
}

<div class="page-scroll">

    @* Stats *@
    <div class="stats-row">
        <div class="stat-chip"><strong>@_vm?.Stats.ActiveGrows</strong>Aktive Runs</div>
        <div class="stat-chip"><strong>@_vm?.Tents.Count</strong>Aktive Zelte</div>
        <div class="stat-chip"><strong>@_openTasks.Count</strong>Offen heute</div>
    </div>

    <div class="ops-layout">
        @* Zelt-Karten *@
        <div>
            <div class="tents-grid">
                @foreach (var tentCard in _vm?.Tents ?? [])
                {
                    var climateKeys    = new HashSet<string> { "temperature", "humidity", "vpd" };
                    var climateMetrics = tentCard.LiveMetrics.Where(m => climateKeys.Contains(m.Key)).ToList();
                    var hydroMetrics   = tentCard.Tent.ActiveGrows.Any(g => g.IrrigationType == IrrigationType.ActiveHydro)
                        ? tentCard.LiveMetrics.Where(m => !climateKeys.Contains(m.Key)).Take(4).ToList()
                        : new List<MetricCard>();

                    <TentCard Tent="tentCard.Tent"
                              ClimateMetrics="climateMetrics"
                              ReservoirMetrics="hydroMetrics"
                              OnOpen="() => Nav.NavigateTo($"/zelte/{tentCard.Tent.Id}")"
                              OnOpenGrow="id => Nav.NavigateTo($"/grows/{id}")"/>
                }
            </div>
        </div>

        @* Side Panel *@
        <div class="side-panel">
            @* Aufgaben *@
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="panel-card-title">Heute zu tun</span>
                    <span class="panel-card-count">@_openTasks.Count(t => !t.IsCompleted)</span>
                </div>
                @foreach (var task in _openTasks.Take(6))
                {
                    <div class="task-item">
                        <div class="task-check @(task.IsCompleted ? "done" : "")"
                             @onclick="() => ToggleTask(task)">
                            @if (task.IsCompleted)
                            {
                                <svg width="8" height="8" viewBox="0 0 8 8">
                                    <path d="M1 4l2 2 4-4" stroke="oklch(10% 0.02 155)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                                </svg>
                            }
                        </div>
                        <div style="flex:1; @(task.IsCompleted ? "opacity:0.45" : "")">
                            <div class="task-title" style="@(task.IsCompleted ? "text-decoration:line-through" : "")">
                                @task.Title
                            </div>
                            <div class="task-sub">
                                @task.GrowName · @(task.DueAtUtc?.ToLocalTime().ToString("HH:mm") ?? "ohne Termin")
                            </div>
                        </div>
                        <div class="prio-dot prio-@task.Priority.ToString().ToLower()"></div>
                    </div>
                }
            </div>

            @* Reservoir / Addback *@
            @if (_addbackItems.Any())
            {
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Reservoir / Addback</span>
                    </div>
                    @foreach (var item in _addbackItems)
                    {
                        var trend = item.EcTrend; // "up" | "down" | "neutral"
                        <div class="addback-item">
                            <div class="addback-name">@item.GrowName</div>
                            <div class="addback-detail">@item.TentName · @item.HydroStyle</div>
                            <div class="addback-ec">
                                <span class="addback-ec-val @trend">@item.Ec?.ToString("0.00")</span>
                                <span class="addback-ec-unit">mS/cm @(trend == "up" ? "↑" : trend == "down" ? "↓" : "–")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Recommendation))
                            {
                                <div class="addback-rec">@item.Recommendation</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;

    private HomeDashboardViewModel? _vm;
    private List<GrowTask> _openTasks = new();
    private List<AddbackItem> _addbackItems = new();  // eigenes ViewModel
    private List<(string Location, string Title, string Body)> _criticalItems = new();
    private Timer? _timer;

    protected override async Task OnInitializedAsync() {
        await LoadData();

        // Live-Refresh alle 10 Sekunden (wie bisher data-live-interval-ms="10000")
        _timer = new Timer(async _ => {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task LoadData() {
        _vm = await Composer.BuildAsync();
        _openTasks = _vm.DueSoonTasks.OrderBy(t => t.DueAtUtc ?? t.CreatedAtUtc).ToList();

        _criticalItems = _vm.ActiveDeviations
            .Where(d => d.Severity == DeviationSeverity.Critical)
            .Select(d => (
                Location: TentNameForDeviation(d),
                Title: d.Metric.ToString(),
                Body: d.Recommendation
            )).ToList();

        // Addback: nur Hydro-Grows mit EC-Daten
        _addbackItems = _vm.Tents
            .SelectMany(tc => tc.Tent.ActiveGrows
                .Where(g => g.IrrigationType == IrrigationType.ActiveHydro)
                .Where(g => g.LatestMeasurement?.ReservoirEc.HasValue == true)
                .Select(g => new AddbackItem {
                    GrowName       = g.Name,
                    TentName       = tc.Tent.Name,
                    HydroStyle     = g.HydroStyle.ToString(),
                    Ec             = g.LatestMeasurement?.ReservoirEc,
                    EcTrend        = GetEcTrend(_vm.ActiveDeviations, g.Id),
                    Recommendation = _vm.ActiveDeviations
                        .FirstOrDefault(d => d.GrowId == g.Id && d.Metric == DeviationMetric.Ec)
                        ?.Recommendation,
                }))
            .ToList();
    }

    private async Task Refresh() => await LoadData();

    private async Task ToggleTask(GrowTask task) {
        task.IsCompleted = !task.IsCompleted;
        if (task.IsCompleted)
            await TaskRepo.CompleteAsync(task.Id);
        else
            await TaskRepo.UncompleteAsync(task.Id);
    }

    private string GetEcTrend(List<GrowDeviation> devs, int growId) {
        var dev = devs.FirstOrDefault(d => d.GrowId == growId && d.Metric == DeviationMetric.Ec);
        if (dev is null) return "neutral";
        if (dev.Recommendation.Contains("gestiegen")) return "up";
        if (dev.Recommendation.Contains("gefallen"))  return "down";
        return "neutral";
    }

    private string TentNameForDeviation(GrowDeviation dev) {
        var card = _vm?.Tents.FirstOrDefault(t => t.Tent.ActiveGrows.Any(g => g.Id == dev.GrowId));
        return card?.Tent.Name ?? dev.GrowName;
    }

    public void Dispose() => _timer?.Dispose();

    // Lokales ViewModel für Addback-Panel
    private class AddbackItem {
        public string GrowName       { get; set; } = "";
        public string TentName       { get; set; } = "";
        public string HydroStyle     { get; set; } = "";
        public double? Ec            { get; set; }
        public string EcTrend        { get; set; } = "neutral";
        public string? Recommendation { get; set; }
    }
}
