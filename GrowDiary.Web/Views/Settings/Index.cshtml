@model SettingsViewModel
@{
    ViewData["Title"] = "Einstellungen";
}

<section class="page-hero glass-panel compact-hero single-column">
    <div>
        <span class="eyebrow">Einstellungen</span>
        <h1>Home Assistant, Templates & Backup</h1>
        <p class="lead">Hier verbindest du die App mit Home Assistant, ordnest Sensoren zu und kannst dein Setup sichern.</p>
    </div>
</section>

<div class="settings-layout top-gap-lg">
    <section class="content-stack">
        <article class="glass-panel form-card">
            <div class="section-header">
                <div>
                    <h2>Home Assistant</h2>
                    <p class="muted">Nutze die lokale REST-API deines Home Assistant. Basis-URL und Long-Lived Access Token reichen aus.</p>
                </div>
            </div>
            <form method="post" asp-action="SaveHomeAssistant" class="form-shell">
                @Html.AntiForgeryToken()
                <div class="form-grid two">
                    <div class="field">
                        <label asp-for="HomeAssistant.BaseUrl">Base URL</label>
                        <input asp-for="HomeAssistant.BaseUrl" placeholder="http://homeassistant.local:8123" />
                    </div>
                    <div class="field">
                        <label asp-for="HomeAssistant.AccessToken">Access Token</label>
                        <input asp-for="HomeAssistant.AccessToken" type="password" placeholder="Long-Lived Access Token" />
                    </div>
                </div>
                <label class="checkbox-field top-gap">
                    <input asp-for="HomeAssistant.Enabled" type="checkbox" />
                    <span>Home-Assistant-Verbindung aktivieren</span>
                </label>
                <div class="form-actions between">
                    <a class="btn btn-ghost" asp-action="BackupDatabase">Backup herunterladen</a>
                    <button class="btn btn-primary" type="submit">Verbindung speichern</button>
                </div>
            </form>
        </article>

        @foreach (var tent in Model.Tents)
        {
            <article class="glass-panel form-card top-gap-lg">
                <div class="section-header">
                    <div>
                        <h2>@tent.Name</h2>
                        <p class="muted">Entity-Zuordnung für dieses Zelt – passend für AC Infinity oder Govee.</p>
                    </div>
                </div>
                <form method="post" asp-action="SaveTent" asp-route-id="@tent.Id" class="form-shell">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@tent.Id" />
                    <input type="hidden" name="DisplayOrder" value="@tent.DisplayOrder" />
                    <input type="hidden" name="AccentColor" value="@tent.AccentColor" />
                    <div class="form-grid two">
                        <div class="field">
                            <label>Name</label>
                            <input name="Name" value="@tent.Name" />
                        </div>
                        <div class="field">
                            <label>Typ</label>
                            <input name="Kind" value="@tent.Kind" />
                        </div>
                        <div class="field">
                            <label>Temperatur Entity</label>
                            <input name="TemperatureEntityId" value="@tent.TemperatureEntityId" placeholder="sensor.ac_infinity_temperature" />
                        </div>
                        <div class="field">
                            <label>Luftfeuchte Entity</label>
                            <input name="HumidityEntityId" value="@tent.HumidityEntityId" placeholder="sensor.ac_infinity_humidity" />
                        </div>
                        <div class="field">
                            <label>VPD Entity</label>
                            <input name="VpdEntityId" value="@tent.VpdEntityId" placeholder="sensor.ac_infinity_vpd" />
                        </div>
                        <div class="field">
                            <label>Licht / Status Entity</label>
                            <input name="LightEntityId" value="@tent.LightEntityId" placeholder="switch.ac_infinity_light" />
                        </div>
                        <div class="field">
                            <label>Lichtzyklus</label>
                            <input name="LightCycle" value="@tent.LightCycle" placeholder="18/6 oder 12/12" />
                        </div>
                        <div class="field">
                            <label>PPFD Entity</label>
                            <input name="PpfdEntityId" value="@tent.PpfdEntityId" placeholder="sensor.hauptzelt_ppfd" />
                        </div>
                        <div class="field">
                            <label>PPFD Zielwert</label>
                            <input name="PpfdTarget" value="@tent.PpfdTarget" placeholder="650" />
                        </div>
                        <div class="field">
                            <label>Reservoir pH Entity</label>
                            <input name="ReservoirPhEntityId" value="@tent.ReservoirPhEntityId" placeholder="sensor.rdwc_ph" />
                        </div>
                        <div class="field">
                            <label>Reservoir EC Entity</label>
                            <input name="ReservoirEcEntityId" value="@tent.ReservoirEcEntityId" placeholder="sensor.rdwc_ec" />
                        </div>
                        <div class="field">
                            <label>Wasserstand Entity</label>
                            <input name="ReservoirLevelEntityId" value="@tent.ReservoirLevelEntityId" placeholder="sensor.rdwc_level_liters" />
                        </div>
                        <div class="field">
                            <label>Wassertemperatur Entity</label>
                            <input name="ReservoirTempEntityId" value="@tent.ReservoirTempEntityId" placeholder="sensor.rdwc_water_temp" />
                        </div>
                        <div class="field">
                            <label>ORP Sensor</label>
                            <input name="OrpEntityId" value="@tent.OrpEntityId" placeholder="sensor.rdwc_orp" />
                        </div>
                        <div class="field">
                            <label>Gelöster Sauerstoff</label>
                            <input name="DissolvedOxygenEntityId" value="@tent.DissolvedOxygenEntityId" placeholder="sensor.rdwc_do" />
                        </div>
                        <div class="field">
                            <label>CO₂ ppm</label>
                            <input name="Co2EntityId" value="@tent.Co2EntityId" placeholder="sensor.hauptzelt_co2" />
                        </div>
                        <div class="field full">
                            <label>Kamera / Webcam Entity</label>
                            <input name="CameraEntityId" value="@tent.CameraEntityId" placeholder="camera.hauptzelt_overview" />
                        </div>
                    </div>
                    <div class="field full top-gap">
                        <label>Notizen</label>
                        <textarea name="Notes" rows="3">@tent.Notes</textarea>
                    </div>
                    <div class="form-actions">
                        <button class="btn btn-primary" type="submit">@tent.Name speichern</button>
                    </div>
                </form>
            </article>
        }
    </section>

    <aside class="sidebar-stack">
        <article class="glass-panel side-card">
            <h3>Starter-Mapping</h3>
            <ul class="clean-list">
                <li><strong>Hauptzelt</strong>: AC Infinity Controller 69 Pro</li>
                <li><strong>Anzuchtzelt</strong>: Govee Bluetooth Temp/Humidity</li>
                <li>Hydro-Werte separat nur für das Zelt mappen, in dem RDWC läuft.</li>
            </ul>
        </article>
        <article class="glass-panel side-card">
            <h3>Grow-Templates</h3>
            <ul class="clean-list">
                @foreach (var template in Model.Templates)
                {
                    <li>
                        <strong>@template.Name</strong>
                        <span>@template.Description</span>
                    </li>
                }
            </ul>
        </article>
        <article class="glass-panel side-card">
            <h3>Backup</h3>
            <p class="muted">Die lokale SQLite-Datenbank kannst du jederzeit herunterladen. Für einen vollständigen Umzug sichere zusätzlich den Upload-Ordner mit deinen Fotos.</p>
            <a class="btn btn-ghost full-width" asp-action="BackupDatabase">DB-Backup laden</a>
        </article>
    </aside>
</div>
