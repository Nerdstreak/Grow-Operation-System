@model AddbackViewModel
@{
    ViewData["Title"] = "Addback-Rechner";
}

<section class="page-hero glass-panel hero-tool single-column">
    <div>
        <span class="eyebrow">Addback-Rechner</span>
        <h1>@Model.GrowName</h1>
        <p class="lead">Mischungsformel: wie viel konzentrierte Nährlösung ist nötig, um den Reservoir-EC auf den Zielwert zu bringen?</p>
    </div>
</section>

<div class="page-body">
    <section class="glass-panel" style="padding: 28px 32px;">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid four">
                <div class="field">
                    <label for="ReservoirLiters">Reservoir (L)</label>
                    <input id="ReservoirLiters" name="ReservoirLiters" type="number" step="0.1" min="0.1"
                           value="@Model.ReservoirLiters?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                           placeholder="z. B. 60" />
                    <small class="addback-form-hint">aktuelles Gesamtvolumen im Reservoir</small>
                </div>
                <div class="field">
                    <label for="EcIst">EC aktuell (mS/cm)</label>
                    <input id="EcIst" name="EcIst" type="number" step="0.01" min="0"
                           value="@Model.EcIst?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                           placeholder="z. B. 0.8" />
                    <small class="addback-form-hint">EC deiner letzten Messung</small>
                </div>
                <div class="field">
                    <label for="EcZiel">Ziel-EC (mS/cm)</label>
                    <input id="EcZiel" name="EcZiel" type="number" step="0.01" min="0"
                           value="@Model.EcZiel?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                           placeholder="z. B. 1.2" />
                    <small class="addback-form-hint">angestrebter EC nach dem Addback</small>
                </div>
                <div class="field">
                    <label for="EcStock">Addback-EC (mS/cm)</label>
                    <input id="EcStock" name="EcStock" type="number" step="0.01" min="0"
                           value="@((Model.EcStock ?? 3.0).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))"
                           placeholder="z. B. 3.0" />
                    <small class="addback-form-hint">EC deiner vorgemischten Stammlösung</small>
                </div>
            </div>
            <div class="top-gap">
                <button type="submit" class="btn btn-primary">Berechnen</button>
            </div>
        </form>
    </section>

    @if (Model.Result is { } result)
    {
        <section class="glass-panel" style="padding: 28px 32px;">
            @if (result.ErrorMessage is not null)
            {
                <p class="text-danger"><strong>@result.ErrorMessage</strong></p>
            }
            else if (!result.NeedsAddback)
            {
                <p style="font-size: 1.1rem;"><strong>Kein Addback nötig</strong></p>
                <p class="muted">EC liegt bereits im Zielbereich oder darüber.</p>
            }
            else
            {
                <div class="addback-result">
                    <p class="addback-result__liters">@result.LitersToAdd?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) L</p>
                    <p style="font-size: 1.05rem; font-weight: 600; margin: 0;">Addback hinzufügen</p>
                    <p class="muted" style="margin: 0;">Reservoir danach: @result.NewReservoirVolume?.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture) L</p>
                </div>
            }
        </section>
    }

    <div>
        <a class="btn btn-ghost" asp-action="Details" asp-route-id="@Model.GrowId">← Zurück zum Grow</a>
    </div>
</div>
