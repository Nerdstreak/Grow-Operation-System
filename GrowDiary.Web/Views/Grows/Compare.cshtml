@model ComparePageViewModel
@{
    ViewData["Title"] = "Analyse";
}

<section class="page-hero glass-panel compact-hero single-column">
    <div>
        <span class="eyebrow">Analyse</span>
        <h1>Run gegen Run vergleichen</h1>
        <p class="lead">Vergleiche zwei Grows anhand von Profil, letztem Foto, letzter Messung und den aktuellen Empfehlungen.</p>
    </div>
</section>

<article class="glass-panel form-card top-gap-lg">
    <form method="get" class="form-shell">
        <div class="form-grid two">
            <div class="field">
                <label for="leftGrowId">Linker Grow</label>
                <select id="leftGrowId" name="leftGrowId">
                    <option value="">Bitte wählen</option>
                    @foreach (var grow in Model.GrowOptions)
                    {
                        <option value="@grow.Id" selected="@(Model.LeftGrowId == grow.Id ? "selected" : null)">@grow.Name</option>
                    }
                </select>
            </div>
            <div class="field">
                <label for="rightGrowId">Rechter Grow</label>
                <select id="rightGrowId" name="rightGrowId">
                    <option value="">Bitte wählen</option>
                    @foreach (var grow in Model.GrowOptions)
                    {
                        <option value="@grow.Id" selected="@(Model.RightGrowId == grow.Id ? "selected" : null)">@grow.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Vergleich laden</button>
        </div>
    </form>
</article>

<div class="card-grid two-up top-gap-lg">
    @foreach (var side in new[]
    {
        new { Grow = Model.LeftGrow, Measurement = Model.LeftMeasurement, Photo = Model.LeftPhoto, Recommendations = Model.LeftRecommendations, Title = "Links" },
        new { Grow = Model.RightGrow, Measurement = Model.RightMeasurement, Photo = Model.RightPhoto, Recommendations = Model.RightRecommendations, Title = "Rechts" }
    })
    {
        <article class="glass-panel form-card">
            <div class="section-header">
                <div>
                    <span class="eyebrow">@side.Title</span>
                    <h2>@(side.Grow?.Name ?? "Kein Grow gewählt")</h2>
                    <p class="muted">@(side.Grow?.Profile.Label ?? "Bitte einen Grow auswählen")</p>
                </div>
            </div>

            @if (side.Grow is null)
            {
                <div class="empty-state slim">Wähle oben einen Grow aus.</div>
            }
            else
            {
                <div class="detail-pills">
                    <span class="status-badge status-@side.Grow.Status.ToString().ToLowerInvariant()">@side.Grow.Status</span>
                    <span class="detail-pill">Start @side.Grow.StartDate.ToString("dd.MM.yyyy")</span>
                    <span class="detail-pill">@(side.Grow.Nutrients ?? "kein Dünger hinterlegt")</span>
                </div>

                @if (side.Photo is not null)
                {
                    <img class="grow-thumb" src="@side.Photo.RelativePath" alt="Vergleichsbild" loading="lazy" />
                }

                @if (side.Measurement is not null)
                {
                    <div class="metric-grid compact two-up-inline top-gap">
                        <article class="metric-card accent"><span>Messung</span><strong>@side.Measurement.TakenAt.ToString("dd.MM. HH:mm")</strong></article>
                        <article class="metric-card"><span>Phase</span><strong>@side.Measurement.Stage</strong></article>
                        <article class="metric-card"><span>Höhe</span><strong>@(side.Measurement.HeightCm?.ToString("0.0") ?? "–") cm</strong></article>
                        @if (side.Grow.Profile.IsHydro)
                        {
                            <article class="metric-card"><span>Reservoir EC</span><strong>@(side.Measurement.ReservoirEc?.ToString("0.00") ?? "–")</strong></article>
                        }
                        else
                        {
                            <article class="metric-card"><span>Gieß-pH</span><strong>@(side.Measurement.IrrigationPh?.ToString("0.00") ?? "–")</strong></article>
                        }
                    </div>
                }

                <div class="alert-stack top-gap">
                    @foreach (var item in side.Recommendations.Take(3))
                    {
                        <article class="alert-card @item.Severity">
                            <strong>@item.Title</strong>
                            <p>@item.Message</p>
                        </article>
                    }
                </div>
            }
        </article>
    }
</div>
