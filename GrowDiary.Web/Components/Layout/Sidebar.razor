@inject IJSRuntime JS

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-mark">
            <svg viewBox="0 0 16 16" fill="none" stroke="oklch(10% 0.02 155)" stroke-width="2">
                <path d="M8 14V8"/><path d="M8 8Q11 4 14 4"/><path d="M8 10Q5 7 2 7"/>
            </svg>
        </div>
        <div class="logo-name">Grow OS</div>
        <div class="logo-sub">Operations System</div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section">Haupt</div>
        <NavItem Href="/"        Label="Operations"   Icon="ops"     HasAlert="@_hasAlert" />
        <NavItem Href="/zelte"   Label="Zelte"        Icon="tents" />
        <NavItem Href="/grows"   Label="Aktive Grows" Icon="grows" />

        <div class="nav-section">Mehr</div>
        <NavItem Href="/archiv"  Label="Archiv"       Icon="archive" />
        <NavItem Href="/analyse" Label="Analyse"      Icon="analyse" />
        <NavItem Href="/wissen"  Label="Wissen"       Icon="wissen" />

        <div class="nav-section">System</div>
        <NavItem Href="/einstellungen" Label="Einstellungen" Icon="settings" />
    </nav>

    <div class="sidebar-footer">
        <a href="/grows/new" class="btn btn-primary">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 3v10M3 8h10"/>
            </svg>
            Neuer Run
        </a>
        <button class="theme-toggle"
                @onclick="ToggleTheme"
                title="Theme wechseln"
                aria-label="@ThemeToggleLabel">
            @if (_theme == "dark")
            {
                <svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <circle cx="8" cy="8" r="3" />
                    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.1 3.1l1.4 1.4M11.5 11.5l1.4 1.4M3.1 12.9l1.4-1.4M11.5 4.5l1.4-1.4" />
                </svg>
            }
            else
            {
                <svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M13 10.5A5.5 5.5 0 0 1 5.5 3 5.5 5.5 0 1 0 13 10.5Z" />
                </svg>
            }
        </button>
    </div>
</aside>

@code {
    private string _theme = "dark";
    private bool _hasAlert;
    private string ThemeToggleLabel => _theme == "dark"
        ? "Helles Theme aktivieren"
        : "Dunkles Theme aktivieren";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _theme = await JS.InvokeAsync<string?>("localStorage.getItem", "theme") ?? "dark";
        await ApplyTheme();
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", _theme);
        await ApplyTheme();
    }

    private async Task ApplyTheme()
    {
        await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", _theme);
    }

    // Wird von Home.razor via Cascading-Value oder EventCallback befüllt – Phase 2
    public void SetAlert(bool hasAlert)
    {
        _hasAlert = hasAlert;
        StateHasChanged();
    }
}
