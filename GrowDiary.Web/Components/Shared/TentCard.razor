@inject NavigationManager Nav

<article class="tent-card is-@StatusClass" tabindex="0" @onclick='() => Nav.NavigateTo($"/zelte/{Tent.Id}")' @onkeydown="OpenFromKeyboard">

    @* Header *@
    <div class="tc-header">
        <div>
            <div class="tc-name">@Tent.Name</div>
            <div class="tc-meta">@Tent.Kind · @Tent.ActiveGrowCount @(Tent.ActiveGrowCount == 1 ? "Run" : "Runs") · @HydroStyle</div>
        </div>
        <div class="status-pill @StatusClass">
            <div class="status-dot"></div>
            @StatusLabel
        </div>
    </div>

    @* Klima *@
    <div class="tc-section-label">Klima</div>
    <div class="tc-metrics-row">
        @foreach (var m in _climate)
        {
            <div class="tc-metric">
                <div class="tc-metric-label">@m.Label</div>
                <div class="tc-metric-value @ToneClass(m)">@m.Value</div>
                <div class="tc-metric-unit">@m.Unit</div>
                <div class="tc-metric-target">@(m.Target is not null ? $"Soll {m.Target}" : m.Hint ?? "")</div>
            </div>
        }
    </div>

    @* Reservoir *@
    @if (_reservoir.Any())
    {
        <div class="tc-section-label" style="border-top:1px solid var(--border); padding-top:8px; margin-top:0">Reservoir</div>
        <div class="tc-metrics-row">
            @foreach (var m in _reservoir)
            {
                <div class="tc-metric">
                    <div class="tc-metric-label">@m.Label</div>
                    <div class="tc-metric-value @ToneClass(m)">@m.Value</div>
                    <div class="tc-metric-unit">@m.Unit</div>
                    <div class="tc-metric-target">@(m.Target is not null ? $"Soll {m.Target}" : "")</div>
                </div>
            }
        </div>
    }

    @* Kamera *@
    @if (!string.IsNullOrWhiteSpace(Tent.CameraEntityId))
    {
        <CameraPanel TentId="@Tent.Id" RefreshSeconds="30" Alt="@($"Livebild von {Tent.Name}")" />
    }

    @* Footer *@
    <div class="tc-footer">
        <div class="tc-runs">
            @foreach (var grow in Tent.ActiveGrows.Take(3))
            {
                <div class="tc-run-pill"
                     @onclick:stopPropagation="true"
                     @onclick='() => Nav.NavigateTo($"/grows/{grow.Id}")'>
                    @grow.Name
                </div>
            }
        </div>
        <button class="tc-open-btn" @onclick:stopPropagation="true"
                @onclick='() => Nav.NavigateTo($"/zelte/{Tent.Id}")'>
            Öffnen →
        </button>
    </div>
</article>

@code {
    [Parameter] public Tent Tent { get; set; } = default!;
    [Parameter] public List<MetricCard> Metrics { get; set; } = new();
    [Parameter] public List<GrowDeviation> Deviations { get; set; } = new();

    private static readonly HashSet<string> ClimateKeys  = new() { "temperature", "humidity", "vpd", "ppfd", "light", "light-cycle" };
    private static readonly HashSet<string> ReservoirKeys = new() { "reservoir-ph", "reservoir-ec", "orp", "reservoir-temp", "reservoir-level" };

    private List<MetricCard> _climate    => Metrics.Where(m => ClimateKeys.Contains(m.Key)).Take(4).ToList();
    private List<MetricCard> _reservoir  => Metrics.Where(m => ReservoirKeys.Contains(m.Key)).ToList();

    private string HydroStyle => Tent.ActiveGrows
        .FirstOrDefault(g => g.IrrigationType == IrrigationType.ActiveHydro)
        ?.HydroStyle.ToString() ?? Tent.Kind;

    private string StatusClass
    {
        get
        {
            if (Deviations.Any(d => d.Severity == DeviationSeverity.Critical)) return "crit";
            if (Deviations.Any(d => d.Severity == DeviationSeverity.Warning))  return "warn";
            return "ok";
        }
    }

    private string StatusLabel => StatusClass switch
    {
        "crit" => "kritisch",
        "warn" => "beobachten",
        _      => "stabil"
    };

    private string ToneClass(MetricCard m)
    {
        if (m.Tone is "ok" or "warn" or "crit") return m.Tone;

        var devMetric = m.Key switch
        {
            "reservoir-ph"   => (DeviationMetric?)DeviationMetric.Ph,
            "reservoir-ec"   => DeviationMetric.Ec,
            "reservoir-temp" => DeviationMetric.WaterTemp,
            "vpd"            => DeviationMetric.Vpd,
            "ppfd"           => DeviationMetric.Ppfd,
            _                => null
        };
        if (devMetric is null) return "";

        var worst = Deviations
            .Where(d => d.Metric == devMetric)
            .OrderByDescending(d => (int)d.Severity)
            .FirstOrDefault();

        return worst?.Severity switch
        {
            DeviationSeverity.Critical => "crit",
            DeviationSeverity.Warning  => "warn",
            DeviationSeverity.Ok       => "ok",
            _                          => ""
        };
    }

    private void OpenFromKeyboard(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ")
        {
            Nav.NavigateTo($"/zelte/{Tent.Id}");
        }
    }
}
