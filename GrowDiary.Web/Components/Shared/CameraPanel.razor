@implements IDisposable

<div class="cam-strip">
    <div style="position:relative; aspect-ratio:16/9; overflow:hidden;">
        @if (!string.IsNullOrWhiteSpace(_srcA))
        {
            <img class="cam-img"
                 src="@_srcA"
                 alt="@Alt"
                 width="1280"
                 height="720"
                 fetchpriority="high"
                 style="opacity:@(_active == "a" ? 1 : 0)" />
        }
        @if (!string.IsNullOrWhiteSpace(_srcB))
        {
            <img class="cam-img"
                 src="@_srcB"
                 alt=""
                 width="1280"
                 height="720"
                 style="opacity:@(_active == "b" ? 1 : 0)" />
        }
        <div class="cam-live-badge">
            <div class="cam-live-dot"></div>
            Live
        </div>
        <div class="cam-age">vor @_ageSeconds s</div>
    </div>
</div>

@code {
    [Parameter] public int TentId         { get; set; }
    [Parameter] public int RefreshSeconds { get; set; } = 30;
    [Parameter] public string Alt { get; set; } = "Livebild der Zeltkamera";

    private string _srcA = "";
    private string _srcB = "";
    private string _active = "a";
    private int _ageSeconds = 0;
    private Timer? _refreshTimer;
    private Timer? _ageTimer;
    private DateTimeOffset _lastRefresh = DateTimeOffset.UtcNow;
    private int _lastTentId = -1;
    private bool _disposed;

    protected override void OnInitialized()
    {
        _lastTentId = TentId;
        _srcA = CameraUrl();
        var refreshInterval = TimeSpan.FromSeconds(Math.Max(1, RefreshSeconds));

        _refreshTimer = new Timer(_ =>
        {
            if (_disposed) return;
            Refresh();
            _ = InvokeAsync(StateHasChanged);
        }, null,
        refreshInterval,
        refreshInterval);

        _ageTimer = new Timer(_ =>
        {
            if (_disposed) return;
            _ageSeconds = (int)(DateTimeOffset.UtcNow - _lastRefresh).TotalSeconds;
            _ = InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    protected override void OnParametersSet()
    {
        if (_lastTentId == TentId)
        {
            return;
        }

        _lastTentId = TentId;
        _srcA = CameraUrl();
        _srcB = string.Empty;
        _active = "a";
        _lastRefresh = DateTimeOffset.UtcNow;
        _ageSeconds = 0;
    }

    private void Refresh()
    {
        var url = CameraUrl();
        if (_active == "a") { _srcB = url; _active = "b"; }
        else                { _srcA = url; _active = "a"; }
        _lastRefresh = DateTimeOffset.UtcNow;
        _ageSeconds  = 0;
    }

    private string CameraUrl() =>
        $"/tents/{TentId}/camera-stream?t={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";

    public void Dispose()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        _ageTimer?.Dispose();
    }
}
