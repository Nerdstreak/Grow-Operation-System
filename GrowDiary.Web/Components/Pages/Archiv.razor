@page "/archiv"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject WeekCounterService WeekCounter
@inject NavigationManager Nav

<div class="topbar">
    <span class="topbar-title">Archiv</span>
</div>

<div class="page-scroll">

    <div class="stats-row">
        <div class="stat-chip"><strong>@_grows.Count</strong>Archivierte Runs</div>
        <div class="stat-chip"><strong>@_grows.Count(g => g.Status == GrowStatus.Completed)</strong>Abgeschlossen</div>
        <div class="stat-chip"><strong>@_grows.Count(g => g.Status == GrowStatus.Aborted)</strong>Abgebrochen</div>
    </div>

    <div class="data-table">
        <div class="data-table-header" style="grid-template-columns:2fr 1fr 1fr 1fr 60px">
            <span>Name</span>
            <span>Zelt</span>
            <span>Status</span>
            <span>Zeitraum</span>
            <span></span>
        </div>

        @if (!_grows.Any())
        {
            <div class="empty-hint">Noch keine archivierten Grows.</div>
        }
        else
        {
            @foreach (var g in _grows)
            {
                <div class="data-row" style="grid-template-columns:2fr 1fr 1fr 1fr 60px"
                     @onclick='() => Nav.NavigateTo($"/grows/{g.Id}")'>
                    <div>
                        <div class="row-name">@g.Name</div>
                        <div class="row-sub">@g.Strain @(g.Breeder is not null ? $"· {g.Breeder}" : "")</div>
                    </div>
                    <div class="row-muted">@(g.TentName ?? "–")</div>
                    <div>
                        <span class="badge @(g.Status == GrowStatus.Completed ? "badge-ok" : "badge-neutral")">
                            @(g.Status == GrowStatus.Completed ? "Abgeschlossen" : "Abgebrochen")
                        </span>
                    </div>
                    <div class="row-muted" style="font-size:11px">
                        @g.StartDate.ToString("dd.MM.yy")
                        @if (g.EndDate.HasValue) { <span> – @g.EndDate.Value.ToString("dd.MM.yy")</span> }
                    </div>
                    <div>
                        <button class="tc-open-btn" @onclick:stopPropagation="true"
                                @onclick='() => Nav.NavigateTo($"/grows/{g.Id}")'>→</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<GrowRun> _grows = new();

    protected override Task OnInitializedAsync()
    {
        _grows = GrowRepo.GetArchivedGrows();
        return Task.CompletedTask;
    }
}
