@page "/grows/new"
@page "/grows/{Id:int}/setup"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@inject GrowRepository GrowRepo
@inject TemplateRepository TemplateRepo
@inject CultivationKnowledgeService KnowledgeService
@inject WeekCounterService WeekCounter
@inject AuditRepository AuditRepo
@inject NavigationManager Nav

@if (_loading)
{
    <div class="topbar"><span class="topbar-title">Lade...</span></div>
    <div class="page-scroll"><div class="empty-hint">Lade Grow-Daten...</div></div>
}
else if (_notFound)
{
    <div class="topbar"><span class="topbar-title">Nicht gefunden</span></div>
    <div class="page-scroll"><div class="empty-hint">Grow nicht gefunden.</div></div>
}
else
{
    <div class="topbar">
        <div class="topbar-left">
            <button class="btn" @onclick="Cancel">@(_isEdit ? "<- Grow" : "<- Grows")</button>
            <span class="topbar-sep">/</span>
            <span class="topbar-title">@(_isEdit ? "Setup bearbeiten" : "Neuer Run")</span>
        </div>
        <div class="topbar-right">
            <button class="btn btn-primary" form="grow-form" type="submit" disabled="@_saving">
                @(_saving ? "Speichert..." : _isEdit ? "Speichern" : "Run anlegen")
            </button>
        </div>
    </div>

    <div class="page-scroll">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="panel-card" style="border-color: oklch(66% 0.22 25 / 0.5); margin-bottom:14px">
                <div class="card-pad" style="color:var(--red)">@_error</div>
            </div>
        }

        <EditForm id="grow-form" Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="measurement-layout">
                <div style="display:grid; gap:14px">
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Genetik</span>
                        </div>
                        <div class="card-pad measurement-grid">
                            <div class="field">
                                <label for="grow-name">Name</label>
                                <InputText id="grow-name" class="mono" @bind-Value="_model.Name" autocomplete="off" />
                            </div>
                            <div class="field">
                                <label for="grow-tent">Zelt</label>
                                <InputSelect id="grow-tent" @bind-Value="_model.TentId">
                                    <option value="">Ohne Zuordnung</option>
                                    @foreach (var tent in _tents)
                                    {
                                        <option value="@tent.Id">@tent.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label for="grow-strain">Sorte</label>
                                <InputText id="grow-strain" @bind-Value="_model.Strain" autocomplete="off" placeholder="z. B. Purple Lemonade" />
                            </div>
                            <div class="field">
                                <label for="grow-breeder">Breeder</label>
                                <InputText id="grow-breeder" @bind-Value="_model.Breeder" autocomplete="off" placeholder="z. B. FastBuds" />
                            </div>
                            <div class="field">
                                <label for="grow-seed-type">Samentyp</label>
                                <InputSelect id="grow-seed-type" @bind-Value="_model.SeedType">
                                    @foreach (var item in Enum.GetValues<SeedType>())
                                    {
                                        <option value="@item">@Label(item)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label for="grow-start-material">Startmaterial</label>
                                <select id="grow-start-material" value="@_model.StartMaterial" @onchange="OnStartMaterialChanged">
                                    @foreach (var item in Enum.GetValues<StartMaterial>())
                                    {
                                        <option value="@item">@Label(item)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">System</span>
                        </div>
                        <div class="card-pad measurement-grid">
                            <div class="field">
                                <label for="grow-hydro">Hydro-Stil</label>
                                <InputSelect id="grow-hydro" @bind-Value="_model.HydroStyle">
                                    @foreach (var item in Enum.GetValues<HydroStyle>().Where(x => x != HydroStyle.None))
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label for="grow-water">Wasserquelle</label>
                                <InputSelect id="grow-water" @bind-Value="_model.WaterSource">
                                    @foreach (var item in Enum.GetValues<WaterSource>())
                                    {
                                        <option value="@item">@Label(item)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label for="grow-plants">Pflanzen / Eimer</label>
                                <InputNumber id="grow-plants" class="mono" @bind-Value="_model.PlantCount" min="1" />
                            </div>
                            <div class="field">
                                <label for="grow-reservoir">Reservoir</label>
                                <InputText id="grow-reservoir" @bind-Value="_model.ReservoirSize" autocomplete="off" placeholder="z. B. 60 L" />
                            </div>
                            <div class="field">
                                <label for="grow-container">Netztopf</label>
                                <InputText id="grow-container" @bind-Value="_model.ContainerSize" autocomplete="off" placeholder="z. B. 15 cm" />
                            </div>
                            <div class="field">
                                <label for="grow-light">Licht</label>
                                <InputText id="grow-light" @bind-Value="_model.Light" autocomplete="off" placeholder="z. B. AC Infinity 300W" />
                            </div>
                            <label style="display:flex; align-items:center; gap:8px; font-size:13px; cursor:pointer">
                                <InputCheckbox @bind-Value="_model.HasChiller" />
                                <span>Chiller vorhanden</span>
                            </label>
                        </div>
                    </div>

                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Naehrstoffe & Einstieg</span>
                        </div>
                        <div class="card-pad measurement-grid">
                            <div class="field">
                                <label for="grow-nutrients">Naehrstofflinie</label>
                                <InputText id="grow-nutrients" @bind-Value="_model.Nutrients" autocomplete="off" list="nutrient-suggestions" placeholder="z. B. Athena Blended" />
                                <datalist id="nutrient-suggestions">
                                    @foreach (var suggestion in _nutrientSuggestions)
                                    {
                                        <option value="@suggestion"></option>
                                    }
                                </datalist>
                            </div>
                            <div class="field">
                                <label for="grow-start-date">Startdatum</label>
                                <InputText id="grow-start-date" class="mono" type="date" @bind-Value="_model.StartDate" autocomplete="off" />
                            </div>
                            <div class="field">
                                <label for="grow-entry">Einstiegspunkt</label>
                                <InputSelect id="grow-entry" @bind-Value="_model.EntryPoint">
                                    @foreach (var item in EntryPointOptions)
                                    {
                                        <option value="@item">@Label(item)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label for="grow-days">Tage in Phase</label>
                                <InputNumber id="grow-days" class="mono" @bind-Value="_model.DaysAlreadyInPhase" min="0" />
                            </div>
                            <div class="field">
                                <label for="grow-auto-days">Autoflower-Tage seit Keimung</label>
                                <InputNumber id="grow-auto-days" class="mono" @bind-Value="_model.AutoflowerDaysSinceGermination" min="0" />
                            </div>
                            <div class="field">
                                <label for="grow-flip">Flip-Datum</label>
                                <InputText id="grow-flip" class="mono" type="date" @bind-Value="_model.FlipDate" autocomplete="off" />
                            </div>
                        </div>
                    </div>

                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Notizen</span>
                        </div>
                        <div class="card-pad">
                            <div class="field">
                                <label for="grow-notes">Notizen zum Run</label>
                                <InputTextArea id="grow-notes" rows="4" @bind-Value="_model.Notes" autocomplete="off" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="side-panel">
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Status</span>
                        </div>
                        <div class="card-pad" style="display:grid; gap:10px">
                            <div class="field">
                                <label for="grow-status">Run-Status</label>
                                <InputSelect id="grow-status" @bind-Value="_model.Status">
                                    @foreach (var item in Enum.GetValues<GrowStatus>())
                                    {
                                        <option value="@item">@Label(item)</option>
                                    }
                                </InputSelect>
                            </div>
                            <button class="btn btn-primary full-width" type="submit" disabled="@_saving">
                                @(_saving ? "Speichert..." : _isEdit ? "Speichern" : "Run anlegen")
                            </button>
                            <button class="btn full-width" type="button" @onclick="Cancel">Abbrechen</button>
                        </div>
                    </div>

                    @if (_templates.Any() && !_isEdit)
                    {
                        <div class="panel-card">
                            <div class="panel-card-header">
                                <span class="panel-card-title">Templates</span>
                            </div>
                            <div class="card-pad" style="display:grid; gap:8px">
                                @foreach (var template in _templates.Take(6))
                                {
                                    <button class="btn full-width" type="button" @onclick="() => ApplyTemplate(template.Id)">
                                        @template.Name
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery] public int? TemplateId { get; set; }

    private GrowFormViewModel _model = new();
    private List<Tent> _tents = new();
    private List<GrowTemplate> _templates = new();
    private IReadOnlyList<string> _nutrientSuggestions = Array.Empty<string>();
    private bool _loading = true;
    private bool _saving;
    private bool _notFound;
    private string? _error;
    private bool _isEdit => Id.HasValue;

    protected override Task OnParametersSetAsync()
    {
        _loading = true;
        _notFound = false;
        _error = null;

        _tents = GrowRepo.GetTents();
        _templates = TemplateRepo.GetAll();
        _nutrientSuggestions = KnowledgeService.GetHydroProgramNames();

        if (Id.HasValue)
        {
            var grow = GrowRepo.GetGrow(Id.Value);
            if (grow is null)
            {
                _notFound = true;
                _loading = false;
                return Task.CompletedTask;
            }

            _model = GrowFormViewModel.FromGrow(grow);
        }
        else if (TemplateId.HasValue && TemplateRepo.Get(TemplateId.Value) is { } template)
        {
            _model = GrowFormViewModel.FromTemplate(template);
        }
        else
        {
            _model = new GrowFormViewModel();
        }

        _loading = false;
        return Task.CompletedTask;
    }

    private IEnumerable<GrowEntryPoint> EntryPointOptions =>
        Enum.GetValues<GrowEntryPoint>()
            .Where(e => _model.StartMaterial != StartMaterial.Clone
                        || e != GrowEntryPoint.Germination);

    private void OnStartMaterialChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<StartMaterial>(e.Value?.ToString(), out var val))
        {
            _model.StartMaterial = val;
            if (val == StartMaterial.Clone && _model.EntryPoint == GrowEntryPoint.Germination)
                _model.EntryPoint = GrowEntryPoint.Seedling;
        }
    }

    private async Task SaveAsync()
    {
        if (_saving)
        {
            return;
        }

        _saving = true;
        _error = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Name))
            {
                _error = "Bitte gib dem Grow einen Namen.";
                return;
            }

            if (!DateTime.TryParse(_model.StartDate, out _))
            {
                _error = "Bitte gib ein gueltiges Startdatum ein.";
                return;
            }

            if (_model.NeedsFlipDate && !DateTime.TryParse(_model.FlipDate, out _))
            {
                _error = "Bitte gib ein gueltiges Flip-Datum ein.";
                return;
            }

            var grow = _model.ToGrow();
            int growId;

            if (_isEdit)
            {
                var existing = GrowRepo.GetGrow(Id!.Value);
                if (existing is null)
                {
                    _notFound = true;
                    return;
                }

                grow.Id = existing.Id;
                grow.CreatedAtUtc = existing.CreatedAtUtc;
                GrowRepo.UpdateGrow(grow);
                growId = grow.Id;
                AuditRepo.Add(new AuditEntry
                {
                    GrowId = growId,
                    EntityType = "Grow",
                    EntityId = growId,
                    Action = "Setup geaendert",
                    Summary = $"Setup von \"{grow.Name}\" aktualisiert. Status: {grow.Status}, System: {grow.HydroStyle}."
                });
            }
            else
            {
                growId = GrowRepo.CreateGrow(grow);
                var savedGrow = GrowRepo.GetGrow(growId)!;
                var weekInfo = WeekCounter.Calculate(savedGrow);
                if (savedGrow.Status == GrowStatus.Planning &&
                    weekInfo.State is not GrowCounterState.WaitingForGermination and not GrowCounterState.WaitingForRooting and not GrowCounterState.NoData)
                {
                    savedGrow.Status = GrowStatus.Running;
                    GrowRepo.UpdateGrow(savedGrow);
                }

                AuditRepo.Add(new AuditEntry
                {
                    GrowId = growId,
                    EntityType = "Grow",
                    EntityId = growId,
                    Action = "Grow angelegt",
                    Summary = $"Setup \"{_model.Name}\" wurde erstellt{(_model.TemplateId.HasValue ? $" auf Basis des Templates #{_model.TemplateId}" : string.Empty)}."
                });
            }

            Nav.NavigateTo($"/grows/{growId}");
        }
        catch (Exception ex)
        {
            _error = $"Speichern fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyTemplate(int templateId)
        => Nav.NavigateTo($"/grows/new?templateId={templateId}");

    private void Cancel()
        => Nav.NavigateTo(_isEdit ? $"/grows/{Id}" : "/grows");

    private static string Label(object value) => value switch
    {
        GrowStatus.Planning => "Geplant",
        GrowStatus.Running => "Laufend",
        GrowStatus.Completed => "Abgeschlossen",
        GrowStatus.Aborted => "Abgebrochen",
        SeedType.Feminized => "Feminisiert",
        SeedType.Autoflower => "Autoflower",
        SeedType.Regular => "Regular",
        StartMaterial.Seed => "Samen",
        StartMaterial.Clone => "Steckling",
        WaterSource.RO => "RO-Wasser",
        WaterSource.Tap => "Leitungswasser",
        WaterSource.Mixed => "Gemischt",
        GrowEntryPoint.Germination => "Keimung",
        GrowEntryPoint.Seedling => "Anzucht",
        GrowEntryPoint.Veg => "Veg",
        GrowEntryPoint.Flower => "Bluete",
        GrowEntryPoint.Flush => "Flush",
        _ => value.ToString() ?? string.Empty
    };
}
