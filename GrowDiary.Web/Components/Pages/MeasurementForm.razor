@page "/grows/{Id:int}/messung"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject JournalRepository JournalRepo
@inject NavigationManager Nav

@if (_loading)
{
    <div class="topbar"><span class="topbar-title">Lade…</span></div>
    <div class="page-scroll"><div class="empty-hint">Lade Grow-Daten…</div></div>
}
else if (_grow is null)
{
    <div class="topbar"><span class="topbar-title">Nicht gefunden</span></div>
    <div class="page-scroll"><div class="empty-hint">Grow nicht gefunden.</div></div>
}
else
{
    <div class="topbar">
        <div class="topbar-left">
            <button class="btn" @onclick='() => Nav.NavigateTo($"/grows/{Id}")'>← @_grow.Name</button>
        </div>
        <div class="topbar-right">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Speichert…" : "Speichern")</button>
        </div>
    </div>

    <div class="page-scroll">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="panel-card" style="border-color: oklch(66% 0.22 25 / 0.5); margin-bottom:14px">
                <div class="card-pad" style="color:var(--red)">@_error</div>
            </div>
        }

        @if (_saved)
        {
            <div class="panel-card" style="border-color: oklch(74% 0.19 145 / 0.5); margin-bottom:14px">
                <div class="card-pad" style="color:var(--green)">Messung gespeichert.</div>
            </div>
        }

        <div class="measurement-layout">
            <div style="display:grid; gap:14px">
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Reservoir</span>
                    </div>
                    <div class="card-pad measurement-grid">
                        <div class="field">
                            <label>pH</label>
                            <input class="mono" type="number" step="0.01" @bind="_measurement.ReservoirPh" />
                        </div>
                        <div class="field">
                            <label>EC (mS/cm)</label>
                            <input class="mono" type="number" step="0.01" @bind="_measurement.ReservoirEc" />
                        </div>
                        <div class="field">
                            <label>ORP (mV)</label>
                            <input class="mono" type="number" step="1" @bind="_measurement.OrpMv" />
                        </div>
                        <div class="field">
                            <label>Wassertemperatur (°C)</label>
                            <input class="mono" type="number" step="0.1" @bind="_measurement.ReservoirWaterTempC" />
                        </div>
                        <div class="field">
                            <label>DO (mg/L)</label>
                            <input class="mono" type="number" step="0.1" @bind="_measurement.DissolvedOxygenMgL" />
                        </div>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Klima</span>
                    </div>
                    <div class="card-pad measurement-grid">
                        <div class="field">
                            <label>Temperatur (°C)</label>
                            <input class="mono" type="number" step="0.1" @bind="_measurement.AirTemperatureC" />
                        </div>
                        <div class="field">
                            <label>Luftfeuchte (%)</label>
                            <input class="mono" type="number" step="0.1" @bind="_measurement.HumidityPercent" />
                        </div>
                        <div class="field">
                            <label>PPFD</label>
                            <input class="mono" type="number" step="1" @bind="_measurement.PpfdMol" />
                        </div>
                        <div class="field">
                            <label>CO₂ (ppm)</label>
                            <input class="mono" type="number" step="1" @bind="_measurement.Co2Ppm" />
                        </div>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Notiz (optional)</span>
                    </div>
                    <div class="card-pad" style="display:grid; gap:10px">
                        <div class="field">
                            <label>Titel</label>
                            <input @bind="_journalTitle" placeholder="z. B. Reservoir nachgefüllt" />
                        </div>
                        <div class="field">
                            <label>Notiz</label>
                            <textarea rows="4" @bind="_journalBody" placeholder="Kurz notieren, was heute wichtig war…"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="side-panel">
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Meta</span>
                    </div>
                    <div class="card-pad" style="display:grid; gap:10px">
                        <div class="field">
                            <label>Zeitpunkt</label>
                            <input type="datetime-local" @bind="_takenAtLocal" />
                        </div>
                        <div class="field">
                            <label>Phase</label>
                            <select @bind="_measurement.Stage">
                                @foreach (var stage in Enum.GetValues<GrowStage>())
                                {
                                    <option value="@stage">@stage</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label>Messungs-Notiz</label>
                            <textarea rows="3" @bind="_measurement.Notes" placeholder="Interne Messungsnotiz"></textarea>
                        </div>
                    </div>
                </div>

                @if (_latest is not null)
                {
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Letzte Messung</span>
                        </div>
                        <div class="card-pad" style="display:grid; gap:7px; font-size:12px">
                            <div style="display:flex; justify-content:space-between"><span class="text-muted">pH</span><span class="text-mono">@(_latest.ReservoirPh?.ToString("0.00") ?? "–")</span></div>
                            <div style="display:flex; justify-content:space-between"><span class="text-muted">EC</span><span class="text-mono">@(_latest.ReservoirEc?.ToString("0.00") ?? "–")</span></div>
                            <div style="display:flex; justify-content:space-between"><span class="text-muted">Temp</span><span class="text-mono">@(_latest.AirTemperatureC?.ToString("0.0") ?? "–")</span></div>
                            <div style="display:flex; justify-content:space-between"><span class="text-muted">LF</span><span class="text-mono">@(_latest.HumidityPercent?.ToString("0") ?? "–")</span></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string? _error;

    private GrowRun? _grow;
    private Measurement? _latest;
    private Measurement _measurement = new();

    private string? _journalTitle;
    private string? _journalBody;
    private string _takenAtLocal = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");

    protected override Task OnInitializedAsync()
    {
        _grow = GrowRepo.GetGrow(Id);
        if (_grow is null)
        {
            _loading = false;
            return Task.CompletedTask;
        }

        _latest = GrowRepo.GetLatestMeasurement(Id);
        _measurement = new Measurement
        {
            GrowId = Id,
            Stage = _grow.Stage,
            Source = ValueOrigin.Manual,
            TakenAt = DateTime.Now
        };

        if (_latest is not null)
        {
            _measurement.ReservoirPh = _latest.ReservoirPh;
            _measurement.ReservoirEc = _latest.ReservoirEc;
            _measurement.AirTemperatureC = _latest.AirTemperatureC;
            _measurement.HumidityPercent = _latest.HumidityPercent;
            _measurement.ReservoirWaterTempC = _latest.ReservoirWaterTempC;
            _measurement.OrpMv = _latest.OrpMv;
            _measurement.DissolvedOxygenMgL = _latest.DissolvedOxygenMgL;
            _measurement.PpfdMol = _latest.PpfdMol;
            _measurement.Co2Ppm = _latest.Co2Ppm;
        }

        _loading = false;
        return Task.CompletedTask;
    }

    private Task SaveAsync()
    {
        if (_grow is null || _saving)
        {
            return Task.CompletedTask;
        }

        _saving = true;
        _saved = false;
        _error = null;

        try
        {
            if (!DateTime.TryParse(_takenAtLocal, out var takenAtLocal))
            {
                _error = "Ungültiger Zeitpunkt.";
                return Task.CompletedTask;
            }

            _measurement.GrowId = Id;
            _measurement.TakenAt = takenAtLocal;

            var measurementId = GrowRepo.CreateMeasurement(_measurement);

            if (!string.IsNullOrWhiteSpace(_journalBody))
            {
                JournalRepo.Create(new JournalEntry
                {
                    GrowId = Id,
                    MeasurementId = measurementId,
                    Title = string.IsNullOrWhiteSpace(_journalTitle) ? "Messungsnotiz" : _journalTitle.Trim(),
                    Body = _journalBody.Trim(),
                    EntryType = JournalEntryType.Note,
                    Source = ValueOrigin.Manual,
                    OccurredAtUtc = _measurement.TakenAt.ToUniversalTime()
                });
            }

            _saved = true;
            Nav.NavigateTo($"/grows/{Id}");
        }
        catch (Exception ex)
        {
            _error = $"Speichern fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }

        return Task.CompletedTask;
    }
}
