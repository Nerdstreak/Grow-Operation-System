@page "/grows/{Id:int}/journal/create"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject JournalRepository JournalRepo
@inject NavigationManager Nav

@if (_loading)
{
    <div class="topbar"><span class="topbar-title">Lade...</span></div>
    <div class="page-scroll"><div class="empty-hint">Lade Grow-Daten...</div></div>
}
else if (_grow is null)
{
    <div class="topbar"><span class="topbar-title">Nicht gefunden</span></div>
    <div class="page-scroll"><div class="empty-hint">Grow nicht gefunden.</div></div>
}
else
{
    <div class="topbar">
        <div class="topbar-left">
            <button class="btn" @onclick='() => Nav.NavigateTo($"/grows/{Id}")'>← @_grow.Name</button>
        </div>
        <div class="topbar-right">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Speichert..." : "Speichern")</button>
        </div>
    </div>

    <div class="page-scroll">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="panel-card" style="border-color: oklch(66% 0.22 25 / 0.5); margin-bottom:14px">
                <div class="card-pad" style="color:var(--red)">@_error</div>
            </div>
        }

        <div class="panel-card">
            <div class="panel-card-header">
                <span class="panel-card-title">Notiz</span>
            </div>
            <div class="card-pad" style="display:grid; gap:14px">
                <div class="two-col-grid">
                    <div class="field">
                        <label>Titel</label>
                        <input @bind="_title" placeholder="z. B. Reservoir gewechselt" />
                    </div>
                    <div class="field">
                        <label>Zeitpunkt</label>
                        <input type="datetime-local" @bind="_occurredAtLocal" />
                    </div>
                    <div class="field">
                        <label>Typ</label>
                        <select @bind="_entryType">
                            @foreach (var type in Enum.GetValues<JournalEntryType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label>Text</label>
                    <textarea rows="7" @bind="_body" placeholder="Was ist passiert, was wurde gemacht, was ist aufgefallen?"></textarea>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private GrowRun? _grow;

    private string? _title;
    private string? _body;
    private JournalEntryType _entryType = JournalEntryType.Note;
    private DateTime _occurredAtLocal = DateTime.Now;
    private int? _loadedId;

    protected override Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return Task.CompletedTask;
        }

        _loadedId = Id;
        _loading = true;
        _saving = false;
        _error = null;
        _title = null;
        _body = null;
        _entryType = JournalEntryType.Note;
        _occurredAtLocal = DateTime.Now;
        _grow = GrowRepo.GetGrow(Id);
        _loading = false;
        return Task.CompletedTask;
    }

    private Task SaveAsync()
    {
        if (_grow is null || _saving)
        {
            return Task.CompletedTask;
        }

        if (string.IsNullOrWhiteSpace(_body))
        {
            _error = "Bitte einen Notiztext eingeben.";
            return Task.CompletedTask;
        }

        _saving = true;
        _error = null;

        try
        {
            JournalRepo.Create(new JournalEntry
            {
                GrowId = Id,
                Title = string.IsNullOrWhiteSpace(_title) ? null : _title.Trim(),
                Body = _body.Trim(),
                EntryType = _entryType,
                Source = ValueOrigin.Manual,
                OccurredAtUtc = _occurredAtLocal.ToUniversalTime()
            });

            Nav.NavigateTo($"/grows/{Id}");
        }
        catch (Exception ex)
        {
            _error = $"Speichern fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }

        return Task.CompletedTask;
    }
}
