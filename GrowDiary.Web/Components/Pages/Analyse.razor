@page "/analyse"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject WeekCounterService WeekCounter

<div class="topbar">
    <span class="topbar-title">Analyse</span>
</div>

<div class="page-scroll">

    @* Grow-Auswahl *@
    <div class="two-col-grid" style="margin-bottom:20px">
        <div class="field">
            <label>Grow A</label>
            <select class="analyse-select" style="width:100%" @onchange="e => OnLeftChanged(e.Value?.ToString())">
                <option value="">– Grow wählen –</option>
                @foreach (var g in _allGrows)
                {
                    <option value="@g.Id" selected="@(_leftId == g.Id)">@g.Name (@g.StartDate.ToString("MM.yy"))</option>
                }
            </select>
        </div>
        <div class="field">
            <label>Grow B</label>
            <select class="analyse-select" style="width:100%" @onchange="e => OnRightChanged(e.Value?.ToString())">
                <option value="">– Grow wählen –</option>
                @foreach (var g in _allGrows)
                {
                    <option value="@g.Id" selected="@(_rightId == g.Id)">@g.Name (@g.StartDate.ToString("MM.yy"))</option>
                }
            </select>
        </div>
    </div>

    @if (_left is null && _right is null)
    {
        <div class="empty-hint">Wähle zwei Grows zum Vergleichen.</div>
    }
    else
    {
        @* Vergleichstabelle *@
        <div class="card" style="overflow:auto">
            <table class="compare-table" style="width:100%">
                <thead>
                    <tr>
                        <th>Kennzahl</th>
                        <th>@(_left?.Name ?? "–")</th>
                        <th>@(_right?.Name ?? "–")</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Strain</td>
                        <td>@(_left?.Strain ?? "–")</td>
                        <td>@(_right?.Strain ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Medium</td>
                        <td>@(_left?.MediumType.ToString() ?? "–")</td>
                        <td>@(_right?.MediumType.ToString() ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Hydro-Stil</td>
                        <td>@(_left?.HydroStyle == HydroStyle.None ? "–" : _left?.HydroStyle.ToString() ?? "–")</td>
                        <td>@(_right?.HydroStyle == HydroStyle.None ? "–" : _right?.HydroStyle.ToString() ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Nährstoffe</td>
                        <td>@(_left?.Nutrients ?? "–")</td>
                        <td>@(_right?.Nutrients ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Startdatum</td>
                        <td>@(_left?.StartDate.ToString("dd.MM.yy") ?? "–")</td>
                        <td>@(_right?.StartDate.ToString("dd.MM.yy") ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Pflanzen</td>
                        <td>@(_left?.PlantCount?.ToString() ?? "–")</td>
                        <td>@(_right?.PlantCount?.ToString() ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Messungen</td>
                        <td>@(_left?.MeasurementCount.ToString() ?? "–")</td>
                        <td>@(_right?.MeasurementCount.ToString() ?? "–")</td>
                    </tr>
                    @* Letzte Messung *@
                    @{
                        var lm = _left?.LatestMeasurement;
                        var rm = _right?.LatestMeasurement;
                    }
                    <tr>
                        <td>EC (letzte Messung)</td>
                        <td class="@EcClass(lm?.ReservoirEc)">@(lm?.ReservoirEc?.ToString("0.00") ?? "–")</td>
                        <td class="@EcClass(rm?.ReservoirEc)">@(rm?.ReservoirEc?.ToString("0.00") ?? "–")</td>
                    </tr>
                    <tr>
                        <td>pH (letzte Messung)</td>
                        <td class="@PhClass(lm?.ReservoirPh)">@(lm?.ReservoirPh?.ToString("0.0") ?? "–")</td>
                        <td class="@PhClass(rm?.ReservoirPh)">@(rm?.ReservoirPh?.ToString("0.0") ?? "–")</td>
                    </tr>
                    <tr>
                        <td>Temperatur (letzte)</td>
                        <td>@(lm?.AirTemperatureC?.ToString("0.0") ?? "–") °C</td>
                        <td>@(rm?.AirTemperatureC?.ToString("0.0") ?? "–") °C</td>
                    </tr>
                    <tr>
                        <td>Luftfeuchte (letzte)</td>
                        <td>@(lm?.HumidityPercent?.ToString("0") ?? "–") %</td>
                        <td>@(rm?.HumidityPercent?.ToString("0") ?? "–") %</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<GrowRun> _allGrows = new();
    private int? _leftId;
    private int? _rightId;
    private GrowRun? _left;
    private GrowRun? _right;

    protected override Task OnInitializedAsync()
    {
        _allGrows = GrowRepo.GetAllGrows();
        return Task.CompletedTask;
    }

    private void OnLeftChanged(string? val)
    {
        _leftId = int.TryParse(val, out var id) ? id : null;
        _left   = _leftId.HasValue ? GrowRepo.GetGrow(_leftId.Value) : null;
    }

    private void OnRightChanged(string? val)
    {
        _rightId = int.TryParse(val, out var id) ? id : null;
        _right   = _rightId.HasValue ? GrowRepo.GetGrow(_rightId.Value) : null;
    }

    private static string EcClass(double? ec) => ec switch
    {
        >= 1.6 and <= 2.0 => "td-ok",
        >= 1.2 and < 1.6  => "td-warn",
        > 2.0             => "td-warn",
        _                 => ""
    };

    private static string PhClass(double? ph) => ph switch
    {
        >= 5.8 and <= 6.2 => "td-ok",
        >= 5.5 and < 5.8  => "td-warn",
        > 6.2 and <= 6.5  => "td-warn",
        _                 => ""
    };
}
