@page "/zelte/{Id:int}"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject HomeAssistantService HaService
@inject GrowDashboardComposer Composer
@inject WeekCounterService WeekCounter
@inject NavigationManager Nav
@inject ILogger<TentDetail> Logger

@if (_loading)
{
    <div class="topbar"><span class="topbar-title">Lade…</span></div>
    <div class="page-scroll"><div class="empty-hint">Lade Zelt-Daten…</div></div>
}
else if (_tent is null)
{
    <div class="topbar"><span class="topbar-title">Nicht gefunden</span></div>
    <div class="page-scroll"><div class="empty-hint">Zelt nicht gefunden.</div></div>
}
else
{
    <div class="topbar">
        <div class="topbar-left">
            <button class="btn" @onclick='() => Nav.NavigateTo("/zelte")'>← Zelte</button>
            <span class="topbar-sep">/</span>
            <span class="topbar-title">@_tent.Name</span>
        </div>
        <div class="topbar-right">
            <button class="btn" @onclick="RefreshAsync">Aktualisieren</button>
        </div>
    </div>

    <div class="page-scroll">

        @* Metriken *@
        <div class="metric-row">
            @foreach (var m in _metrics)
            {
                <div class="metric-block">
                    <div class="metric-block-label">@m.Label</div>
                    <div class="metric-block-val @m.Tone">@m.Value</div>
                    <div class="metric-block-unit">@m.Unit</div>
                    @if (m.Target is not null)
                    {
                        <div class="metric-block-range">Soll: @m.Target</div>
                    }
                </div>
            }
        </div>

        <div class="detail-layout">

            <div>
                @* Kamera *@
                @if (!string.IsNullOrWhiteSpace(_tent.CameraEntityId))
                {
                    <div class="cam-large-wrap" style="margin-bottom:20px">
                        <CameraPanel TentId="@_tent.Id" RefreshSeconds="30" />
                    </div>
                }

                @* Aktive Grows *@
                <div class="section-label">Aktive Grows</div>
                @if (!_tent.ActiveGrows.Any())
                {
                    <div class="empty-hint" style="padding:30px 0">Keine aktiven Grows in diesem Zelt.</div>
                }
                else
                {
                    <div class="data-table">
                        @foreach (var grow in _tent.ActiveGrows)
                        {
                            var devs = _deviations.Where(d => d.GrowId == grow.Id).ToList();
                            var gw   = WeekCounter.Calculate(grow);
                            <div class="data-row" style="grid-template-columns:2fr 1fr 1fr 80px"
                                 @onclick='() => Nav.NavigateTo($"/grows/{grow.Id}")'>
                                <div>
                                    <div class="row-name">@grow.Name</div>
                                    <div class="row-sub">@grow.Strain @(grow.Breeder is not null ? $"· {grow.Breeder}" : "")</div>
                                </div>
                                <div>
                                    <span class="badge @StageBadge(gw.State)">@gw.Label</span>
                                </div>
                                <div>
                                    @if (devs.Any(d => d.Severity == DeviationSeverity.Critical))
                                    {
                                        <span class="badge badge-crit">kritisch</span>
                                    }
                                    else if (devs.Any(d => d.Severity == DeviationSeverity.Warning))
                                    {
                                        <span class="badge badge-warn">beobachten</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-ok">stabil</span>
                                    }
                                </div>
                                <div>
                                    <button class="tc-open-btn" @onclick:stopPropagation="true"
                                            @onclick='() => Nav.NavigateTo($"/grows/{grow.Id}")'>→</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Side Panel *@
            <div class="side-panel">

                @* Zelt-Info *@
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Info</span>
                    </div>
                    <div style="padding:12px 14px; display:grid; gap:8px; font-size:12px">
                        <div style="display:flex; justify-content:space-between">
                            <span style="color:var(--muted)">Typ</span>
                            <span>@_tent.Kind</span>
                        </div>
                        <div style="display:flex; justify-content:space-between">
                            <span style="color:var(--muted)">Aktive Runs</span>
                            <span>@_tent.ActiveGrowCount</span>
                        </div>
                    </div>
                </div>

                @* Abweichungen *@
                @if (_deviations.Any())
                {
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="panel-card-title">Hinweise</span>
                            <span class="panel-card-count">@_deviations.Count</span>
                        </div>
                        @foreach (var d in _deviations.Take(6))
                        {
                            <div class="focus-card @(d.Severity == DeviationSeverity.Critical ? "crit-border" : "warn-border")">
                                <div class="focus-label">@d.GrowName · @d.Metric</div>
                                <div class="focus-body">@d.Recommendation</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private Tent? _tent;
    private List<MetricCard> _metrics = new();
    private List<GrowDeviation> _deviations = new();
    private int? _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }

        _loadedId = Id;
        await LoadAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _tent = GrowRepo.GetTent(Id);
        if (_tent is null)
        {
            _metrics.Clear();
            _deviations.Clear();
            _loading = false;
            return;
        }

        var settings     = GrowRepo.GetHomeAssistantSettings();
        var measurements = GrowRepo.GetMeasurementsForTent(Id);
        Dictionary<string, HomeAssistantState> states;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(4));
            states = await HaService.GetStatesAsync(settings, _tent, cts.Token);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "HA-States fuer Zelt {TentId} konnten nicht geladen werden.", _tent.Id);
            states = new();
        }

        _metrics = Composer.BuildTentMetrics(_tent, states, measurements);
        foreach (var m in _metrics)
            m.Target = TargetRange(m.Key);

        _deviations = _tent.ActiveGrows
            .SelectMany(g => Composer.BuildDeviationsForGrow(g, measurements))
            .ToList();

        _loading = false;
    }

    private static string? TargetRange(string key) => key switch
    {
        "temperature"    => "22–26 °C",
        "humidity"       => "55–65 %",
        "vpd"            => "0.8–1.2",
        "reservoir-ph"   => "5.8–6.2",
        "reservoir-ec"   => "1.6–2.0",
        "reservoir-temp" => "18–22",
        "orp"            => "300–400",
        "ppfd"           => "400–600",
        _                => null,
    };

    private static string StageBadge(GrowCounterState s) => s switch
    {
        GrowCounterState.Vegetating    => "badge-ok",
        GrowCounterState.Flowering     => "badge-warn",
        GrowCounterState.Autoflowering => "badge-warn",
        _                              => "badge-neutral",
    };
}
