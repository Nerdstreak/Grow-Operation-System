@page "/"
@rendermode InteractiveServer
@inject GrowRepository GrowRepo
@inject TaskRepository TaskRepo
@inject HomeAssistantService HaService
@inject GrowDashboardComposer Composer
@inject ILogger<Home> Logger
@implements IDisposable

@* Topbar *@
<div class="topbar">
    <span class="topbar-title">Operations</span>
    <div class="topbar-right">
        <button class="btn" @onclick="RefreshAsync">Aktualisieren</button>
    </div>
</div>

@* Alert Bar – nur bei kritischen Abweichungen *@
@if (_criticals.Any())
{
    <div class="alert-bar">
        <div class="alert-dot"></div>
        <strong>@_criticals[0].Location – @_criticals[0].Metric</strong>
        <span>@_criticals[0].Body</span>
        @if (_criticals.Count > 1)
        {
            <span class="alert-bar-more">+@(_criticals.Count - 1) weitere →</span>
        }
    </div>
}

<div class="page-scroll">

    @* Stats *@
    <div class="stats-row">
        <div class="stat-chip"><strong>@(_stats?.ActiveGrows ?? 0)</strong>Aktive Runs</div>
        <div class="stat-chip"><strong>@_tentCards.Count</strong>Aktive Zelte</div>
        <div class="stat-chip"><strong>@_openTasks.Count(t => t.Status == GrowTaskStatus.Open)</strong>Offen heute</div>
    </div>

    <div class="ops-layout">

        @* Zelt-Karten *@
        <div>
            <div class="tents-grid">
                @if (_loading)
                {
                    <div class="empty-hint">Lade Daten…</div>
                }
                else if (!_tentCards.Any())
                {
                    <div class="empty-hint">Keine aktiven Zelte gefunden.</div>
                }
                else
                {
                    @foreach (var card in _tentCards)
                    {
                        <TentCard Tent="@card.Tent"
                                  Metrics="@card.LiveMetrics"
                                  Deviations="@card.Deviations" />
                    }
                }
            </div>
        </div>

        @* Side Panel *@
        <div class="side-panel">

            @* Aufgaben *@
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="panel-card-title">Heute zu tun</span>
                    <span class="panel-card-count">@_openTasks.Count(t => t.Status == GrowTaskStatus.Open)</span>
                </div>
                @if (!_openTasks.Any())
                {
                    <div style="padding:14px; font-size:12px; color:var(--faint)">Keine offenen Aufgaben.</div>
                }
                <TaskList Tasks="_openTasks" OnToggle="ToggleTask" ShowGrowName="true" ShowPriority="true" />
            </div>

            @* Reservoir / Addback *@
            @if (_addbackItems.Any())
            {
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="panel-card-title">Reservoir / Addback</span>
                    </div>
                    @foreach (var item in _addbackItems)
                    {
                        <div class="addback-item">
                            <div class="addback-name">@item.GrowName</div>
                            <div class="addback-detail">@item.TentName · @item.HydroStyle</div>
                            <div class="addback-ec">
                                <span class="addback-ec-val @item.EcTrend">@item.Ec?.ToString("0.00")</span>
                                <span class="addback-ec-unit">mS/cm @(item.EcTrend == "up" ? "↑" : item.EcTrend == "down" ? "↓" : "–")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Recommendation))
                            {
                                <div class="addback-rec">@item.Recommendation</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _loading = true;
    private DashboardStats? _stats;
    private List<TentCardData> _tentCards = new();
    private List<GrowTask> _openTasks = new();
    private List<AddbackItem> _addbackItems = new();
    private List<CriticalAlert> _criticals = new();
    private Timer? _timer;
    private readonly SemaphoreSlim _loadLock = new(1, 1);
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        _timer = new Timer(_ => _ = OnTimerTickAsync(), null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task OnTimerTickAsync()
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            await LoadDataAsync();
            if (!_disposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Home timer refresh ist fehlgeschlagen.");
        }
    }

    private async Task LoadDataAsync()
    {
        await _loadLock.WaitAsync();
        try
        {
            if (_disposed)
            {
                return;
            }

            _loading = true;

        var settings = GrowRepo.GetHomeAssistantSettings();
        var tents    = GrowRepo.GetTents().Where(t => t.ActiveGrowCount > 0).ToList();
        _stats       = GrowRepo.GetDashboardStats();
        _openTasks   = TaskRepo.GetDueSoon(10);

        var cards      = new List<TentCardData>();
        var deviations = new List<GrowDeviation>();

        // Alle HA-Abfragen parallel starten
        var tentTasks = tents.Select(async tent =>
        {
            var measurements = GrowRepo.GetMeasurementsForTent(tent.Id);
            Dictionary<string, HomeAssistantState> states;
            try
            {
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(4));
                states = await HaService.GetStatesAsync(settings, tent, cts.Token);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "HA-States für Zelt {TentId} konnten nicht geladen werden.", tent.Id);
                states = new();
            }

            var metrics = Composer.BuildTentMetrics(tent, states, measurements);
            foreach (var m in metrics)
                m.Target = TargetRange(m.Key);

            var tentDevs = tent.ActiveGrows
                .SelectMany(g => Composer.BuildDeviationsForGrow(g, measurements))
                .ToList();

            return new TentCardData { Tent = tent, LiveMetrics = metrics, Deviations = tentDevs };
        });

        var results = await Task.WhenAll(tentTasks);
        foreach (var r in results)
        {
            cards.Add(r);
            deviations.AddRange(r.Deviations);
        }

        _tentCards = cards;

        // Kritische Alerts
        _criticals = deviations
            .Where(d => d.Severity == DeviationSeverity.Critical)
            .Select(d => new CriticalAlert
            {
                Location = _tentCards
                    .FirstOrDefault(t => t.Tent.ActiveGrows.Any(g => g.Id == d.GrowId))
                    ?.Tent.Name ?? d.GrowName,
                Metric = d.Metric.ToString(),
                Body   = d.Recommendation,
            })
            .Take(5)
            .ToList();

        // Addback-Items
        _addbackItems = _tentCards
            .SelectMany(tc => tc.Tent.ActiveGrows
                .Where(g => g.IrrigationType == IrrigationType.ActiveHydro
                         && g.LatestMeasurement?.ReservoirEc.HasValue == true)
                .Select(g =>
                {
                    var ecDev = deviations.FirstOrDefault(d => d.GrowId == g.Id && d.Metric == DeviationMetric.Ec);
                    return new AddbackItem
                    {
                        GrowName       = g.Name,
                        TentName       = tc.Tent.Name,
                        HydroStyle     = g.HydroStyle.ToString(),
                        Ec             = g.LatestMeasurement!.ReservoirEc,
                        EcTrend        = ecDev?.Recommendation.Contains("gestiegen") == true ? "up"
                                       : ecDev?.Recommendation.Contains("gefallen")  == true ? "down"
                                       : "neutral",
                        Recommendation = ecDev?.Recommendation,
                    };
                }))
            .ToList();

        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Home data refresh ist fehlgeschlagen.");
        }
        finally
        {
            _loading = false;
            _loadLock.Release();
        }
    }

    private async Task RefreshAsync()
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleTask(GrowTask task)
    {
        if (task.Status == GrowTaskStatus.Done)
        {
            task.Status = GrowTaskStatus.Open;
            TaskRepo.SetStatus(task.Id, GrowTaskStatus.Open);
        }
        else
        {
            task.Status = GrowTaskStatus.Done;
            TaskRepo.SetStatus(task.Id, GrowTaskStatus.Done);
        }
    }

    private static string? TargetRange(string key) => key switch
    {
        "temperature"   => "22–26 °C",
        "humidity"      => "55–65 %",
        "vpd"           => "0.8–1.2",
        "reservoir-ph"  => "5.8–6.2",
        "reservoir-ec"  => "1.6–2.0",
        "reservoir-temp"=> "18–22",
        "orp"           => "300–400",
        "ppfd"          => "400–600",
        _               => null,
    };

    public void Dispose()
    {
        _disposed = true;
        _timer?.Dispose();
    }

    // Lokale ViewModels
    private sealed class TentCardData
    {
        public Tent Tent             { get; set; } = new();
        public List<MetricCard> LiveMetrics { get; set; } = new();
        public List<GrowDeviation> Deviations { get; set; } = new();
    }

    private sealed class AddbackItem
    {
        public string GrowName        { get; set; } = "";
        public string TentName        { get; set; } = "";
        public string HydroStyle      { get; set; } = "";
        public double? Ec             { get; set; }
        public string EcTrend         { get; set; } = "neutral";
        public string? Recommendation { get; set; }
    }

    private sealed class CriticalAlert
    {
        public string Location { get; set; } = "";
        public string Metric   { get; set; } = "";
        public string Body     { get; set; } = "";
    }
}
