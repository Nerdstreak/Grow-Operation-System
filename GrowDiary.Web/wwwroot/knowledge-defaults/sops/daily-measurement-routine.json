{
  "schemaVersion": "1.0",
  "id": "daily-measurement-routine",
  "name": "Tägliche Messroutine",
  "type": "Recurring",
  "estimatedDurationMinutes": 8,
  "applicableSetups": ["RDWC", "DWC"],
  "triggers": [
    {
      "type": "Schedule",
      "intervalDays": 1
    }
  ],
  "requiredMaterials": [
    "pH-Messgerät (kalibriert)",
    "EC-Messgerät",
    "ORP-Messgerät (optional, kann via HA)",
    "DO-Messgerät (optional, kann via HA)",
    "Thermometer für Wassertemperatur"
  ],
  "steps": [
    {
      "id": "s1",
      "order": 1,
      "title": "Visueller Check",
      "stepType": "Action",
      "description": "Lösungsfarbe, Geruch, Wurzelaussehen und Schaumbildung beurteilen. Auffälligkeiten notieren.",
      "expectedInputs": ["waterColor", "waterSmell", "rootCondition", "foamPresent"],
      "photoRequired": false,
      "photoRecommended": true
    },
    {
      "id": "s2",
      "order": 2,
      "title": "pH messen",
      "stepType": "Measurement",
      "description": "pH-Wert der Nährstofflösung messen.",
      "expectedInputs": ["ph"],
      "photoRequired": false,
      "photoRecommended": false
    },
    {
      "id": "s3",
      "order": 3,
      "title": "Hauptmessungen",
      "stepType": "Measurement",
      "description": "EC, ORP, Sauerstoffgehalt (DO) und Wassertemperatur messen.",
      "expectedInputs": ["ec", "orp", "do", "waterTemp"],
      "photoRequired": false,
      "photoRecommended": false
    },
    {
      "id": "s4",
      "order": 4,
      "title": "Werte mit Sollwerten abgleichen",
      "stepType": "Confirmation",
      "description": "Das System zeigt Abweichungen gegenüber den Sollwerten. Messung bestätigen. Anomalien werden automatisch geloggt.",
      "photoRequired": false,
      "photoRecommended": false
    }
  ],
  "sources": [
    {
      "type": "UserDocument",
      "title": "SOP-RDWC-CAN-N1: pH- und Nährstoff-Stabilisierung",
      "reference": "Abschnitt 3: Mess- und Dokumentationsroutine",
      "url": null,
      "credibility": "High"
    }
  ]
}
